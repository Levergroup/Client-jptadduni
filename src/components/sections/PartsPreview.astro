---
/**
 * PartsPreview.astro – Parts preview section for JP Tadduni home page.
 * 4 sample part cards with chrome border treatment.
 */

const parts = [
  {
    name: "Muncie 4-Speed",
    description: "M20, M21, M22 Rock Crusher — complete units, cases, and components.",
    tag: "Manual Transmission",
  },
  {
    name: "T56 Magnum",
    description: "6-speed manual transmission for LS swaps, Vipers, and Challengers.",
    tag: "Manual Transmission",
  },
  {
    name: "Positraction Units",
    description: "Limited-slip differentials for GM, Ford, Mopar, and more.",
    tag: "Driveline",
  },
  {
    name: "Ring & Pinion Sets",
    description: "Ratio changes and replacements for most domestic axle assemblies.",
    tag: "Driveline",
  },
];
---

<section class="py-20 sm:py-28 bg-jp-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14">
      <div>
        <p class="font-body text-xs font-semibold tracking-[0.25em] uppercase text-jp-red mb-3">Parts &amp; Components</p>
        <h2 class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl text-jp-white leading-tight">
          Need a Specific Part?
        </h2>
        <p class="font-body text-jp-muted mt-3 max-w-lg leading-relaxed">
          We stock and source hard-to-find drivetrain components. Classic muscle car parts,
          performance upgrades, OEM replacements — just ask.
        </p>
      </div>
      <a href="/parts" class="btn-secondary text-sm whitespace-nowrap self-start md:self-auto" style="animation: none;">
        View Parts →
      </a>
    </div>

    <!-- Parts grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
      {parts.map((part) => (
        <div
          class="group flex flex-col gap-4 p-6 bg-jp-black border border-jp-chrome/20 hover:border-jp-chrome/50 transition-all duration-300"
          style="box-shadow: inset 0 0 0 0 rgba(192,192,192,0.05);"
        >
          <!-- Tag -->
          <span class="font-body text-xs font-semibold uppercase tracking-widest text-jp-chrome/60 border border-jp-chrome/20 px-2 py-0.5 self-start">
            {part.tag}
          </span>

          <!-- Part name -->
          <h3 class="font-heading font-bold text-xl text-jp-white leading-snug group-hover:text-jp-chrome transition-colors">
            {part.name}
          </h3>

          <!-- Description -->
          <p class="font-body text-jp-muted text-sm leading-relaxed flex-1">
            {part.description}
          </p>

          <!-- CTA -->
          <a
            href="/contact"
            class="font-body text-xs font-semibold uppercase tracking-widest text-jp-chrome/60 hover:text-jp-chrome transition-colors flex items-center gap-1.5"
          >
            Inquire About This Part
            <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Source note -->
    <p class="font-body text-jp-muted text-sm text-center italic">
      Don't see what you need? We source hard-to-find drivetrain components.
      <a href="/contact" class="text-jp-chrome hover:text-white transition-colors not-italic font-semibold"> Just ask →</a>
    </p>

  </div>
</section>
