---
/**
 * PartsPreview.astro – Parts preview for JP Tadduni home page.
 * Light gray background, 4 white product cards with image placeholders.
 */

const phone = "(475) XXX-XXXX";
const phoneHref = "tel:+14750000000";

const parts = [
  {
    name: "Muncie 4-Speed",
    desc: "Classic muscle car 4-speed transmission units and components",
    tag: "Classic Car Parts",
  },
  {
    name: "T56 Magnum",
    desc: "6-speed manual transmission for high performance applications",
    tag: "Manual Transmissions",
  },
  {
    name: "Positraction Units",
    desc: "Limited slip differentials for GM and Ford applications",
    tag: "Differential Parts",
  },
  {
    name: "Ring & Pinion Sets",
    desc: "Gear sets for all major rear axle applications",
    tag: "Ring & Pinion",
  },
];
---

<section class="py-16 sm:py-24 bg-jp-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
      <div>
        <span class="section-label">Parts &amp; Components</span>
        <h2 class="section-title">Transmission &amp; Driveline Parts</h2>
        <p class="section-sub max-w-xl">
          We stock and source hard-to-find components.
          Can't find it anywhere else? Call JP.
        </p>
      </div>
      <a href="/parts" class="btn-secondary whitespace-nowrap self-start md:self-auto flex-shrink-0">
        View All Parts →
      </a>
    </div>

    <!-- Parts grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
      {parts.map(part => (
        <div class="parts-card flex flex-col gap-4">
          <!-- Image placeholder -->
          <div
            class="w-full aspect-square bg-jp-light flex flex-col items-center justify-center rounded-md"
            style="min-height: 160px;"
          >
            <svg class="w-12 h-12 text-jp-border mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p class="font-body text-xs text-jp-muted text-center px-4">{part.name}</p>
          </div>

          <!-- Category tag -->
          <span class="inline-block font-body text-xs font-semibold uppercase tracking-wider text-jp-red bg-red-50 px-2 py-1 rounded self-start">
            {part.tag}
          </span>

          <!-- Name -->
          <h3 class="font-heading font-bold text-lg text-jp-charcoal leading-tight">{part.name}</h3>

          <!-- Desc -->
          <p class="font-body text-jp-muted text-sm leading-relaxed flex-1">{part.desc}</p>

          <!-- Inquire button -->
          <a
            href="/contact"
            class="btn-primary text-sm py-2.5 justify-center text-center mt-auto"
          >
            Inquire About This Part →
          </a>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center">
      <p class="font-body text-jp-muted mb-4">
        Don't see what you need? We source hard-to-find parts.
      </p>
      <a href={phoneHref} class="btn-primary">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
        </svg>
        Call Us: {phone}
      </a>
    </div>

  </div>
</section>
