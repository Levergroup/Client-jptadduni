---
/**
 * CTABanner.astro – Urgency CTA banner for JP Tadduni Transmissions.
 * Red background section with booking urgency.
 */
---

<section
  class="relative py-16 sm:py-20 overflow-hidden"
  style="background: #CC0000;"
>
  <!-- Subtle dark grid overlay -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: linear-gradient(rgba(0,0,0,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.08) 1px, transparent 1px); background-size: 40px 40px;"
    aria-hidden="true"
  ></div>

  <!-- Darker red corners -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at 50% 50%, rgba(204,0,0,0) 30%, rgba(100,0,0,0.4) 100%);"
    aria-hidden="true"
  ></div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center relative z-10">

    <h2 class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl text-white leading-tight mb-4">
      Transmission problems don't fix themselves.
      <span class="block opacity-90">Every mile makes it worse.</span>
    </h2>

    <p class="font-body text-white/80 text-lg mb-3 max-w-xl mx-auto leading-relaxed">
      We're currently booking rebuilds — don't wait until it leaves you stranded.
    </p>

    <p class="font-body text-white/60 text-sm mb-10 uppercase tracking-widest font-medium">
      Free Diagnosis · Honest Quote · Written Warranty
    </p>

    <a
      href="/contact"
      class="inline-flex items-center gap-2 bg-white text-jp-red font-heading font-bold text-lg uppercase tracking-wide px-10 py-4 hover:bg-jp-gray transition-all duration-200"
      style="clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));"
    >
      Get Your Free Quote Today →
    </a>

  </div>
</section>
