---
/**
 * Hero.astro
 *
 * Above-the-fold hero section for Duka Masonry.
 * H1 names the prospect's pain (cracking/crumbling masonry) and immediately
 * pivots to the promise. Two CTAs: form and direct call.
 */

const phone = "[PHONE NUMBER]";
const phoneHref = "tel:+1XXXXXXXXXX"; // TODO: replace with real number
---

<section class="bg-charcoal text-offwhite py-20 lg:py-32">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Eyebrow -->
    <p class="text-gold text-sm font-bold uppercase tracking-widest mb-5">
      Waterbury · Naugatuck · The Valley · And Beyond
    </p>

    <!-- H1 — names the pain, promises the fix -->
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
      Your Brick Is Cracking.<br class="hidden md:block" />
      <span class="text-gold">We Fix It Right — the First Time.</span>
    </h1>

    <p class="text-lg md:text-xl text-offwhite/75 mb-10 max-w-2xl leading-relaxed">
      Duka Masonry has been repairing bricks, repointing mortar, and rebuilding chimneys
      across Connecticut for 15+ years. We give straight answers, honest quotes,
      and workmanship that lasts.
    </p>

    <!-- Trust micro-line -->
    <p class="text-sm text-offwhite/50 mb-8">
      Licensed &amp; Insured in CT &nbsp;·&nbsp; Free Quotes &nbsp;·&nbsp; 200+ Projects Completed
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4">
      <a
        href="/contact"
        class="inline-block bg-gold text-charcoal font-bold px-8 py-4 text-lg hover:brightness-105 transition-all text-center"
      >
        Get Your Free Quote
      </a>
      <a
        href={phoneHref}
        class="inline-block border-2 border-offwhite/40 text-offwhite font-semibold px-8 py-4 text-lg hover:border-gold hover:text-gold transition-all text-center"
      >
        Call {phone}
      </a>
    </div>

  </div>
</section>
