---
/**
 * ProofBar.astro – Trust signal bar for JP Tadduni Transmissions.
 * Stats row + badges on a dark band with red accent line.
 */

const stats = [
  { number: "30+",   label: "Years Experience" },
  { number: "1,000s", label: "Rebuilds Completed" },
  { number: "All",   label: "Makes & Models" },
  { number: "100%",  label: "Written Warranty" },
];
---

<div class="relative py-14 bg-jp-dark overflow-hidden">

  <!-- Red top line -->
  <div class="section-divider absolute top-0 left-0 right-0"></div>

  <!-- Subtle glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse at 50% 50%, rgba(204,0,0,0.07) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">

    <!-- Stats -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
      {stats.map((stat) => (
        <div class="text-center">
          <p class="font-heading font-bold text-4xl sm:text-5xl text-jp-white leading-none mb-2">
            {stat.number}
          </p>
          <p class="font-body text-xs font-semibold uppercase tracking-[0.2em] text-jp-muted">
            {stat.label}
          </p>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <div class="h-px mb-10" style="background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);"></div>

    <!-- Trust badges -->
    <div class="flex flex-wrap justify-center items-center gap-8 sm:gap-12 text-xs font-semibold uppercase tracking-widest text-jp-muted">

      <!-- Stars -->
      <div class="flex flex-col items-center gap-2">
        <div class="flex gap-0.5">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4 text-jp-red" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span>5-Star Google Reviews</span>
      </div>

      <div class="h-8 w-px bg-jp-border hidden sm:block"></div>

      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-jp-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        <span>Licensed &amp; Insured</span>
      </div>

      <div class="h-8 w-px bg-jp-border hidden sm:block"></div>

      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-jp-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
        </svg>
        <span>Stratford, CT — Family Owned</span>
      </div>

      <div class="h-8 w-px bg-jp-border hidden sm:block"></div>

      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-jp-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
        </svg>
        <span>Classic Car Experts</span>
      </div>

    </div>

  </div>

  <!-- Red bottom line -->
  <div class="section-divider absolute bottom-0 left-0 right-0"></div>

</div>
