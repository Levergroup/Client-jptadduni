---
/**
 * ServiceAreas.astro – CT service area grid for JP Tadduni Transmissions.
 * Each town links to a dynamic /service-areas/[town] page.
 */

const towns = [
  "Stratford", "Bridgeport", "Milford", "New Haven",
  "Fairfield", "Trumbull", "Shelton", "Derby",
  "Ansonia", "Naugatuck", "Waterbury", "Meriden",
  "Hartford", "Greenwich", "Stamford", "Norwalk", "Danbury",
];

function townSlug(town: string) {
  return town.toLowerCase().replace(/\s+/g, '-');
}
---

<section class="py-20 sm:py-28 bg-jp-black">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-14 max-w-2xl">
      <p class="font-body text-xs font-semibold tracking-[0.25em] uppercase text-jp-red mb-3">Coverage</p>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl text-jp-white leading-tight mb-4">
        Serving All of Connecticut
      </h2>
      <p class="font-body text-jp-muted leading-relaxed">
        Whether you're in the Naugatuck Valley, the Gold Coast, or anywhere in between —
        JP Tadduni is your transmission specialist. We also accept shipped transmissions
        from across the US.
      </p>
    </div>

    <!-- Towns grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2 mb-10">
      {towns.map((town) => (
        <a
          href={`/service-areas/${townSlug(town)}`}
          class="group flex items-center gap-2 px-4 py-3 bg-jp-dark border border-jp-border hover:border-jp-red hover:bg-jp-card transition-all duration-200"
        >
          <span class="w-1 h-1 rounded-full bg-jp-red flex-shrink-0 group-hover:scale-150 transition-transform"></span>
          <span class="font-body text-sm text-jp-muted group-hover:text-jp-gray transition-colors">{town}</span>
        </a>
      ))}
    </div>

    <!-- Ship-in note -->
    <div class="flex items-center gap-4 p-6 border border-jp-red/30 bg-jp-dark max-w-2xl">
      <div class="w-8 h-8 flex-shrink-0 flex items-center justify-center border border-jp-red/50">
        <svg class="w-4 h-4 text-jp-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
        </svg>
      </div>
      <p class="font-body text-sm text-jp-gray leading-relaxed">
        <strong class="text-jp-white">Not in Connecticut?</strong> We accept shipped transmissions from across the US.
        Call us and we'll walk you through the process.
      </p>
    </div>

  </div>
</section>
