---
/**
 * ServiceAreas.astro – CT service area town grid for JP Tadduni home page.
 * White background, town pill tags with red hover.
 */

const towns = [
  { name: "Stratford",   slug: "stratford" },
  { name: "Bridgeport",  slug: "bridgeport" },
  { name: "Milford",     slug: "milford" },
  { name: "New Haven",   slug: "new-haven" },
  { name: "Fairfield",   slug: "fairfield" },
  { name: "Trumbull",    slug: "trumbull" },
  { name: "Shelton",     slug: "shelton" },
  { name: "Derby",       slug: "derby" },
  { name: "Ansonia",     slug: "ansonia" },
  { name: "Naugatuck",   slug: "naugatuck" },
  { name: "Waterbury",   slug: "waterbury" },
  { name: "Meriden",     slug: "meriden" },
  { name: "Hartford",    slug: "hartford" },
  { name: "Greenwich",   slug: "greenwich" },
  { name: "Stamford",    slug: "stamford" },
  { name: "Norwalk",     slug: "norwalk" },
  { name: "Danbury",     slug: "danbury" },
  { name: "Westport",    slug: "westport" },
  { name: "Darien",      slug: "darien" },
  { name: "New Canaan",  slug: "new-canaan" },
  { name: "Wilton",      slug: "wilton" },
  { name: "Ridgefield",  slug: "ridgefield" },
  { name: "Bethel",      slug: "bethel" },
  { name: "Newtown",     slug: "newtown" },
  { name: "Monroe",      slug: "monroe" },
];
---

<section class="py-16 sm:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-12 max-w-2xl">
      <span class="section-label">Coverage</span>
      <h2 class="section-title">Serving All of Connecticut</h2>
      <p class="section-sub">
        Based in Stratford, CT. We accept vehicles from across the state —
        and shipped transmissions from anywhere in the US.
      </p>
    </div>

    <!-- Town grid -->
    <div class="flex flex-wrap gap-2 mb-10">
      {towns.map(town => (
        <a
          href={`/service-areas/${town.slug}`}
          class="inline-flex items-center gap-1.5 px-4 py-2 bg-jp-bg border border-jp-border rounded-full font-body text-sm text-jp-text font-medium hover:bg-jp-red hover:text-white hover:border-jp-red transition-all duration-200"
        >
          <svg class="w-3 h-3 text-jp-red group-hover:text-white" fill="currentColor" viewBox="0 0 8 8" aria-hidden="true">
            <circle cx="4" cy="4" r="3"/>
          </svg>
          {town.name}
        </a>
      ))}
    </div>

    <!-- Ship-in note -->
    <div class="flex items-start gap-4 p-5 bg-jp-bg border border-jp-border rounded-card max-w-2xl">
      <div class="w-10 h-10 flex-shrink-0 flex items-center justify-center bg-jp-red rounded-full">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
        </svg>
      </div>
      <div>
        <p class="font-heading font-bold text-jp-charcoal">Not in Connecticut?</p>
        <p class="font-body text-jp-muted text-sm leading-relaxed mt-1">
          We accept shipped transmissions from across the US.
          Call us and we'll walk you through the process.
        </p>
      </div>
    </div>

  </div>
</section>
