---
/**
 * PainSection.astro – Pain chain for JP Tadduni home page.
 * Light gray background, 3 white cards with red icon accents.
 */

const blocks = [
  {
    title: "It's Not Just Slipping",
    body: "Slipping gears mean your transmission is already failing. Every mile multiplies the damage and the repair cost.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>`,
  },
  {
    title: "Most Shops Just Guess",
    body: "Parts-swapping without a proper diagnosis wastes your money and leaves the real problem unfixed.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    title: "Waiting Costs More",
    body: "A $400 repair today becomes a $2,000 rebuild next month. The longer you wait, the worse it gets.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>`,
  },
];
---

<section class="py-16 sm:py-24 bg-jp-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="text-center mb-12">
      <span class="section-label">Why You Can't Wait</span>
      <h2 class="section-title">
        Ignoring a Transmission Problem<br />
        Always Makes It Worse
      </h2>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {blocks.map(block => (
        <div class="jp-card flex flex-col gap-4">
          <!-- Red icon circle -->
          <div class="w-12 h-12 flex items-center justify-center bg-jp-red rounded-full flex-shrink-0">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <Fragment set:html={block.icon} />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-jp-charcoal">{block.title}</h3>
          <p class="font-body text-jp-muted leading-relaxed">{block.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
