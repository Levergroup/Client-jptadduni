---
/**
 * FAQ.astro – AWE Framework FAQs for JP Tadduni Transmissions.
 * Acknowledge, Wedge, Elaborate — handles real objections.
 * Includes FAQ JSON-LD schema for rich results.
 */

const faqs = [
  {
    q: "How much does a transmission rebuild cost?",
    a: "Rebuilds vary based on the unit and the extent of damage. Most are more affordable than a replacement — and last significantly longer. We give free, honest quotes before any work begins. No guessing, no surprises.",
  },
  {
    q: "How long will the rebuild take?",
    a: "Most rebuilds are completed within 3–5 business days. We'll give you a clear timeline before we start — and we stick to it. If anything changes, we call you first.",
  },
  {
    q: "Do you work on my make and model?",
    a: "All makes, all models — from daily drivers to classic muscle cars. Domestic, import, manual, automatic. If it has a transmission, we can rebuild it.",
  },
  {
    q: "Is the work guaranteed?",
    a: "Yes. Every rebuild comes with a written warranty. We stand behind every job we complete. If there's ever a problem, we make it right — that's the JP Tadduni guarantee.",
  },
  {
    q: "Should I just buy a used transmission instead?",
    a: "Used transmissions are a gamble — you don't know the history or how close to failure they are. A rebuild from JP Tadduni means every component is inspected and brought back to spec. You get a known, warranted unit built to last another 100,000 miles.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<section class="py-20 sm:py-28 bg-jp-dark">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-14">
      <p class="font-body text-xs font-semibold tracking-[0.25em] uppercase text-jp-red mb-3">FAQ</p>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl text-jp-white leading-tight">
        Straight Answers.<br /><span class="text-jp-chrome">No Runaround.</span>
      </h2>
    </div>

    <!-- FAQ items -->
    <div class="flex flex-col divide-y divide-jp-border">
      {faqs.map((faq, i) => (
        <details class="group py-6 cursor-pointer" name="faq">
          <summary class="flex justify-between items-start gap-6 list-none select-none">
            <h3 class="font-heading font-bold text-lg sm:text-xl text-jp-gray group-open:text-jp-white transition-colors leading-snug">
              {faq.q}
            </h3>
            <div class="flex-shrink-0 w-7 h-7 border border-jp-border flex items-center justify-center group-open:border-jp-red group-open:bg-jp-red transition-all duration-200 mt-0.5">
              <svg class="w-3.5 h-3.5 text-jp-muted group-open:text-white group-open:rotate-45 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
              </svg>
            </div>
          </summary>
          <p class="mt-4 font-body text-jp-muted leading-relaxed pr-12">
            {faq.a}
          </p>
        </details>
      ))}
    </div>

    <!-- CTA bridge -->
    <div class="mt-12 pt-8 border-t border-jp-border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="font-body text-jp-muted text-sm">
        Still have questions? We're straight shooters — just ask.
      </p>
      <a href="/contact" class="btn-primary text-sm px-6 py-3" style="animation: none;">
        Talk to Us →
      </a>
    </div>

  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
