---
/**
 * FAQ.astro – Accordion FAQs for JP Tadduni home page.
 * Light gray background, 4 questions with expand/collapse.
 * Includes FAQ JSON-LD schema.
 */

const faqs = [
  {
    q: "How much does a transmission rebuild cost?",
    a: "Every rebuild is different — it depends on the unit and how far the damage has progressed. Most jobs are more affordable than people expect, and always cheaper than a replacement. We give you a straight quote before any work begins. No surprises.",
  },
  {
    q: "How long will the rebuild take?",
    a: "Most transmission rebuilds are completed within 3–5 business days. We'll give you a firm timeline before we start so you can plan accordingly.",
  },
  {
    q: "Do you work on my make and model?",
    a: "All makes, all models. Domestic, foreign, classic, modern, diesel. If it has a transmission, we can rebuild it. Classic and vintage cars are a specialty.",
  },
  {
    q: "Is the work guaranteed?",
    a: "Yes. Every rebuild comes with a written warranty. We stand behind every job — that's not something most shops will say.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(f => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<section class="py-16 sm:py-24 bg-jp-bg">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">

    <!-- Header -->
    <div class="mb-12">
      <span class="section-label">FAQ</span>
      <h2 class="section-title">Questions? We Get These A Lot.</h2>
    </div>

    <!-- Accordion -->
    <div class="flex flex-col gap-3">
      {faqs.map((faq, i) => (
        <details class="group bg-white rounded-card overflow-hidden" style="box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
          <summary class="flex items-center justify-between gap-6 px-6 py-5 cursor-pointer list-none select-none hover:bg-jp-bg transition-colors">
            <h3 class="font-heading font-bold text-lg text-jp-charcoal group-open:text-jp-red transition-colors leading-snug">
              {faq.q}
            </h3>
            <div class="w-8 h-8 flex-shrink-0 flex items-center justify-center bg-jp-bg group-open:bg-jp-red rounded-full transition-all duration-200">
              <svg class="w-4 h-4 text-jp-charcoal group-open:text-white group-open:rotate-45 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
              </svg>
            </div>
          </summary>
          <div class="px-6 pb-5 border-t border-jp-border">
            <p class="font-body text-jp-muted leading-relaxed pt-4">
              {faq.a}
            </p>
          </div>
        </details>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-10 text-center">
      <p class="font-body text-jp-muted mb-4">Still have questions? We're straight shooters — just ask.</p>
      <a href="/contact" class="btn-primary">Talk to Us →</a>
    </div>

  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
