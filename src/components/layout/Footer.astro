---
/**
 * Footer.astro – JP Tadduni Transmissions & Driveline
 * Charcoal footer with 4-column grid.
 */

const phone = "(475) XXX-XXXX";
const phoneHref = "tel:+14750000000";
const email = "info@jptaddunitransmissions.com";
const year = new Date().getFullYear();

const services = [
  { label: "Transmission Rebuild",    href: "/services/transmission-rebuild" },
  { label: "Driveline Services",      href: "/services/driveline" },
  { label: "Classic Car Transmissions", href: "/services/classic-cars" },
  { label: "Manual Transmission",     href: "/services/manual-transmission" },
  { label: "Parts Sales",             href: "/parts" },
  { label: "Vehicles For Sale",       href: "/vehicles" },
  { label: "Diagnostics",             href: "/services/diagnostics" },
];

const topTowns = [
  { name: "Stratford", slug: "stratford" },
  { name: "Bridgeport", slug: "bridgeport" },
  { name: "Milford", slug: "milford" },
  { name: "New Haven", slug: "new-haven" },
  { name: "Fairfield", slug: "fairfield" },
  { name: "Stamford", slug: "stamford" },
];
---

<footer class="w-full bg-jp-charcoal text-gray-400 text-sm">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

    <!-- Brand -->
    <div>
      <div class="mb-4">
        <a href="/">
          <img
            src="/logo.jpg"
            alt="JP Tadduni Transmissions & Driveline"
            class="h-16 w-auto rounded-lg"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>
      <p class="text-gray-400 mb-5 leading-relaxed text-sm italic">
        "Transmissions rebuilt right. Warranted."
      </p>
      <div class="flex flex-col gap-2 text-sm">
        <a href={phoneHref} class="flex items-center gap-2 text-jp-red font-semibold hover:text-red-400 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          {phone}
        </a>
        <a href={`mailto:${email}`} class="flex items-center gap-2 text-gray-400 hover:text-white transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          {email}
        </a>
        <span class="flex items-center gap-2 text-gray-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          </svg>
          Stratford, CT 06615
        </span>
      </div>
    </div>

    <!-- Services -->
    <div>
      <p class="font-heading text-white font-semibold mb-4 uppercase tracking-[0.15em] text-xs border-l-2 border-jp-red pl-3">
        Services
      </p>
      <ul class="space-y-2">
        {services.map(s => (
          <li>
            <a href={s.href} class="hover:text-white hover:pl-1 transition-all duration-200">{s.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Service Areas -->
    <div>
      <p class="font-heading text-white font-semibold mb-4 uppercase tracking-[0.15em] text-xs border-l-2 border-jp-red pl-3">
        Service Areas
      </p>
      <ul class="space-y-2">
        {topTowns.map(t => (
          <li>
            <a href={`/service-areas/${t.slug}`} class="hover:text-white hover:pl-1 transition-all duration-200">{t.name}</a>
          </li>
        ))}
        <li>
          <a href="/service-areas" class="text-jp-red hover:text-red-400 font-semibold transition-colors">
            View All Areas →
          </a>
        </li>
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <p class="font-heading text-white font-semibold mb-4 uppercase tracking-[0.15em] text-xs border-l-2 border-jp-red pl-3">
        Contact
      </p>
      <div class="space-y-3 text-sm">
        <div>
          <p class="text-white font-semibold">Hours</p>
          <p>Mon–Fri: 8:00 AM – 5:00 PM</p>
          <p>Saturday: 8:00 AM – 1:00 PM</p>
          <p>Sunday: Closed</p>
        </div>
        <div class="pt-2 border-t border-gray-700">
          <p class="text-gray-300 text-xs leading-relaxed">
            We also accept shipped transmissions from anywhere in the US.
          </p>
        </div>
        <div>
          <a href="/contact" class="inline-flex items-center gap-1 text-jp-red hover:text-red-400 font-semibold text-sm transition-colors">
            Get A Free Quote →
          </a>
        </div>
      </div>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-gray-500">
      <p>&copy; {year} JP Tadduni Transmissions &amp; Driveline. All rights reserved.</p>
      <p>Stratford, CT | Made with ❤️ by <a href="https://levergroup.agency" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Lever Group Agency</a></p>
    </div>
  </div>

</footer>
