---
/**
 * SEOHead.astro
 *
 * Centralized <head> component for all SEO and meta needs.
 * Accepts per-page props (title, description, canonical URL, OG image, schema)
 * and outputs the appropriate <meta>, <link>, and JSON-LD <script> tags.
 */

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: string; // Serialized JSON-LD structured data
}

const { title, description, canonical, ogImage, schema } = Astro.props;
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />

  <!-- Canonical URL -->
  {canonical && <link rel="canonical" href={canonical} />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Favicon placeholder -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- JSON-LD structured data -->
  {schema && <script type="application/ld+json" set:html={schema} />}

  <title>{title}</title>
</head>
