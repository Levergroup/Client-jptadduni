---
/**
 * Header.astro – JP Tadduni Transmissions & Driveline
 * Charcoal announcement bar + white sticky nav with red CTA.
 */

const phone = "(475) XXX-XXXX";
const phoneHref = "tel:+14750000000";

const navLinks = [
  { label: "Home",          href: "/" },
  { label: "Services",      href: "/services" },
  { label: "Parts",         href: "/parts" },
  { label: "Vehicles",      href: "/vehicles" },
  { label: "Service Areas", href: "/service-areas" },
  { label: "About",         href: "/about" },
  { label: "Contact",       href: "/contact" },
];
---

<!-- Top announcement bar -->
<div class="bg-jp-charcoal text-white py-2 px-4">
  <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
    <span class="font-body text-gray-400 text-xs sm:text-sm hidden sm:block">
      Serving All of Connecticut Since 1995
    </span>
    <a href={phoneHref} class="flex items-center gap-2 text-jp-red font-semibold text-sm hover:text-red-400 transition-colors ml-auto">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
      </svg>
      {phone}
    </a>
  </div>
</div>

<!-- Main nav -->
<header class="w-full bg-white sticky top-0 z-50" style="box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-2 flex items-center justify-between gap-6">

    <!-- Logo -->
    <a href="/" class="flex items-center flex-shrink-0">
      <img
        src="/logo.jpg"
        alt="JP Tadduni Transmissions & Driveline"
        class="h-16 w-auto"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="font-body text-sm font-semibold text-jp-charcoal hover:text-jp-red transition-colors uppercase tracking-wide"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA + hamburger -->
    <div class="flex items-center gap-3 flex-shrink-0">
      <a href="/contact" class="btn-primary hidden sm:inline-flex text-sm px-5 py-2.5">
        Get A Free Quote →
      </a>
      <button
        id="menu-toggle"
        class="lg:hidden p-2 text-jp-charcoal hover:text-jp-red transition-colors"
        aria-label="Open menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="flex-col bg-white border-t border-jp-border lg:hidden">
    <nav class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="font-body text-sm font-semibold text-jp-charcoal hover:text-jp-red hover:bg-jp-bg px-3 py-3 rounded transition-colors uppercase tracking-wide border-l-4 border-transparent hover:border-jp-red"
        >
          {link.label}
        </a>
      ))}
      <div class="mt-3 pt-3 border-t border-jp-border">
        <a href="/contact" class="btn-primary w-full justify-center">Get A Free Quote →</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('open'));
</script>
