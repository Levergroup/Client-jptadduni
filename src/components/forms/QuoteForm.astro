---
/**
 * QuoteForm.astro – Contact/quote form for JP Tadduni Transmissions.
 * POSTs to GHL webhook, redirects to /thank-you on success.
 */

const GHL_WEBHOOK = "https://services.leadconnectorhq.com/hooks/Eg7w8riiQrXu4UuWw942/webhook-trigger/u8MEd63hy6wXrlMDaL5R";
---

<form id="quote-form" class="flex flex-col gap-5" novalidate>

  <!-- Name + Phone row -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div class="flex flex-col gap-1.5">
      <label for="qf-name" class="font-body text-xs font-semibold uppercase tracking-widest text-jp-charcoal">
        Full Name <span class="text-jp-red">*</span>
      </label>
      <input
        type="text" id="qf-name" name="qf-name" required autocomplete="name"
        placeholder="John Smith"
        class="border border-jp-border bg-white text-jp-text placeholder-jp-muted px-4 py-3 text-sm font-body rounded-lg focus:outline-none focus:border-jp-red focus:ring-2 focus:ring-red-100 transition-colors"
      />
    </div>
    <div class="flex flex-col gap-1.5">
      <label for="qf-phone" class="font-body text-xs font-semibold uppercase tracking-widest text-jp-charcoal">
        Phone Number <span class="text-jp-red">*</span>
      </label>
      <input
        type="tel" id="qf-phone" name="qf-phone" required autocomplete="tel"
        placeholder="(860) 555-0100"
        class="border border-jp-border bg-white text-jp-text placeholder-jp-muted px-4 py-3 text-sm font-body rounded-lg focus:outline-none focus:border-jp-red focus:ring-2 focus:ring-red-100 transition-colors"
      />
    </div>
  </div>

  <!-- Email -->
  <div class="flex flex-col gap-1.5">
    <label for="qf-email" class="font-body text-xs font-semibold uppercase tracking-widest text-jp-charcoal">
      Email Address <span class="text-jp-red">*</span>
    </label>
    <input
      type="email" id="qf-email" name="qf-email" required autocomplete="email"
      placeholder="john@example.com"
      class="border border-jp-border bg-white text-jp-text placeholder-jp-muted px-4 py-3 text-sm font-body rounded-lg focus:outline-none focus:border-jp-red focus:ring-2 focus:ring-red-100 transition-colors"
    />
  </div>

  <!-- Vehicle -->
  <div class="flex flex-col gap-1.5">
    <label for="qf-vehicle" class="font-body text-xs font-semibold uppercase tracking-widest text-jp-charcoal">
      Vehicle Year, Make &amp; Model <span class="text-jp-red">*</span>
    </label>
    <input
      type="text" id="qf-vehicle" name="qf-vehicle" required
      placeholder="e.g. 1969 Chevrolet Camaro, 2018 Ford F-150"
      class="border border-jp-border bg-white text-jp-text placeholder-jp-muted px-4 py-3 text-sm font-body rounded-lg focus:outline-none focus:border-jp-red focus:ring-2 focus:ring-red-100 transition-colors"
    />
  </div>

  <!-- Service needed -->
  <div class="flex flex-col gap-1.5">
    <label for="qf-service" class="font-body text-xs font-semibold uppercase tracking-widest text-jp-charcoal">
      Service Needed
    </label>
    <select
      id="qf-service" name="qf-service"
      class="border border-jp-border bg-white text-jp-text px-4 py-3 text-sm font-body rounded-lg focus:outline-none focus:border-jp-red focus:ring-2 focus:ring-red-100 transition-colors appearance-none"
    >
      <option value="">Select service...</option>
      <option value="transmission-rebuild">Transmission Rebuild</option>
      <option value="driveline">Driveline Service</option>
      <option value="classic-car">Classic Car Transmission</option>
      <option value="manual">Manual Transmission</option>
      <option value="parts">Parts Inquiry</option>
      <option value="diagnostics">Diagnostics</option>
      <option value="not-sure">Not Sure</option>
    </select>
  </div>

  <!-- Issue description -->
  <div class="flex flex-col gap-1.5">
    <label for="qf-issue" class="font-body text-xs font-semibold uppercase tracking-widest text-jp-charcoal">
      Describe the Problem <span class="text-jp-red">*</span>
    </label>
    <textarea
      id="qf-issue" name="qf-issue" required rows="4"
      placeholder="Tell us what's happening — slipping, grinding, no movement, vibration, leaking, etc."
      class="border border-jp-border bg-white text-jp-text placeholder-jp-muted px-4 py-3 text-sm font-body rounded-lg focus:outline-none focus:border-jp-red focus:ring-2 focus:ring-red-100 transition-colors resize-none"
    ></textarea>
  </div>

  <!-- Referral -->
  <div class="flex flex-col gap-1.5">
    <label for="qf-referral" class="font-body text-xs font-semibold uppercase tracking-widest text-jp-charcoal">
      How Did You Hear About Us?
    </label>
    <select
      id="qf-referral" name="qf-referral"
      class="border border-jp-border bg-white text-jp-text px-4 py-3 text-sm font-body rounded-lg focus:outline-none focus:border-jp-red focus:ring-2 focus:ring-red-100 transition-colors appearance-none"
    >
      <option value="">Select one...</option>
      <option value="google">Google Search</option>
      <option value="referral">Friend or Family Referral</option>
      <option value="repeat">Returning Customer</option>
      <option value="social">Social Media</option>
      <option value="drive-by">Drove By the Shop</option>
      <option value="other">Other</option>
    </select>
  </div>

  <!-- Error -->
  <p id="form-error" class="hidden font-body text-sm text-jp-red font-medium bg-red-50 px-4 py-3 rounded-lg border border-red-200"></p>

  <!-- Submit -->
  <button
    type="submit" id="submit-btn"
    class="btn-primary w-full justify-center text-base py-4 mt-2"
  >
    <span id="submit-text">Get My Free Quote →</span>
    <span id="submit-loading" class="hidden">Sending...</span>
  </button>

  <p class="font-body text-xs text-jp-muted text-center">
    We'll call <strong>and</strong> email your quote in under 1 hour. No obligation, no pressure.
  </p>

</form>

<script>
  const WEBHOOK = "https://services.leadconnectorhq.com/hooks/Eg7w8riiQrXu4UuWw942/webhook-trigger/u8MEd63hy6wXrlMDaL5R";

  const form       = document.getElementById('quote-form');
  const submitBtn  = document.getElementById('submit-btn');
  const submitText = document.getElementById('submit-text');
  const submitLoad = document.getElementById('submit-loading');
  const errorMsg   = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.checkValidity()) { form.reportValidity(); return; }

    submitBtn.disabled = true;
    submitText.classList.add('hidden');
    submitLoad.classList.remove('hidden');
    errorMsg.classList.add('hidden');

    const payload = {
      full_name:   document.getElementById('qf-name').value.trim(),
      phone:       document.getElementById('qf-phone').value.trim(),
      email:       document.getElementById('qf-email').value.trim(),
      vehicle:     document.getElementById('qf-vehicle').value.trim(),
      service:     document.getElementById('qf-service').value,
      message:     document.getElementById('qf-issue').value.trim(),
      lead_source: document.getElementById('qf-referral').value,
    };

    try {
      await fetch(WEBHOOK, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      window.location.href = '/thank-you';
    } catch {
      errorMsg.textContent = 'Something went wrong. Please call us directly at (860) 717-3158.';
      errorMsg.classList.remove('hidden');
      submitBtn.disabled = false;
      submitText.classList.remove('hidden');
      submitLoad.classList.add('hidden');
    }
  });
</script>
