---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/forms/QuoteForm.astro';
const phone = "(860) 717-3158";
const phoneHref = "tel:+18607173158";
const email = "info@jptaddunitransmissions.com";
const contactSchema = JSON.stringify({
  "@context": "https://schema.org", "@type": "AutoRepair",
  "name": "JP Tadduni Transmissions & Driveline", "telephone": "(860) 717-3158",
  "email": "info@jptaddunitransmissions.com",
  "address": { "@type": "PostalAddress", "streetAddress": "480 Surf Ave", "addressLocality": "Stratford", "addressRegion": "CT", "postalCode": "06615" },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "08:00", "closes": "17:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "13:00" }
  ]
});
---
<Layout title="Contact JP Tadduni Transmissions | Free Diagnosis in Stratford, CT" description="Get a free transmission diagnosis from JP Tadduni in Stratford, CT. Fill out the form or call — we call back within 1 business hour." schema={contactSchema}>

  <section class="bg-jp-bg pt-12 pb-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center">
      <span class="section-label mx-auto">Free Quote</span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl text-jp-charcoal leading-tight mb-4">Get Your Free Quote in Under an Hour</h1>
      <p class="font-body text-lg text-jp-muted max-w-xl mx-auto">Fill out the form and we'll call <em>and</em> email you a quote in under 1 hour. No obligation, no pressure.</p>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <div class="lg:col-span-2 flex flex-col gap-6">
          <div class="jp-card border-l-4 border-jp-red">
            <p class="section-label">Call Us</p>
            <a href={phoneHref} class="font-heading font-bold text-2xl text-jp-charcoal hover:text-jp-red transition-colors block mb-1">{phone}</a>
            <p class="font-body text-jp-muted text-sm">Mon–Fri: 8am–5pm · Sat: 8am–1pm</p>
          </div>
          <div class="jp-card">
            <p class="section-label">Location</p>
            <p class="font-heading font-bold text-lg text-jp-charcoal mb-1">JP Tadduni Transmissions</p>
            <p class="font-body text-jp-muted text-sm">480 Surf Ave, Stratford, CT 06615</p>
          </div>
          <div class="jp-card">
            <p class="section-label">Email</p>
            <a href={`mailto:${email}`} class="font-body text-jp-red text-sm font-semibold">{email}</a>
          </div>
          <div class="p-5 bg-jp-bg border border-jp-border rounded-card">
            <p class="font-heading font-bold text-jp-charcoal mb-2">Shipping Your Transmission?</p>
            <p class="font-body text-jp-muted text-sm leading-relaxed">We accept shipped transmissions from across the US. Call us before shipping.</p>
          </div>
          <div class="flex flex-col gap-2 text-sm font-body text-jp-muted">
            {["Free quote — no obligation","We call & email your quote in under 1 hour","Honest assessment before any work begins","Written warranty on every rebuild"].map(item => (
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4 text-jp-red flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {item}
              </span>
            ))}
          </div>
        </div>

        <div class="lg:col-span-3">
          <div class="jp-card">
            <h2 class="font-heading font-bold text-2xl text-jp-charcoal mb-2">Request Your Free Quote</h2>
            <p class="font-body text-jp-muted text-sm mb-6">Tell us about your vehicle and what's going on. We'll call <strong>and</strong> email your quote in under 1 hour.</p>
            <QuoteForm />
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>
