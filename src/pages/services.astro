---
/**
 * services.astro – All Services overview for JP Tadduni Transmissions.
 * Light theme. 6 alternating service blocks.
 */

import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/sections/CTABanner.astro';

const phone = "(475) XXX-XXXX";
const phoneHref = "tel:+14750000000";

const services = [
  {
    href: "/services/transmission-rebuild",
    name: "Transmission Rebuild",
    tagline: "Is your transmission slipping, grinding, or refusing to shift?",
    desc: "That's not a minor issue — it's the beginning of a complete failure. We tear it completely down, inspect every component, replace what's worn, and rebuild it to spec. Every rebuild includes a written warranty.",
    bullets: ["Complete disassembly and inspection", "All worn components replaced", "Rebuilt to manufacturer specification", "Road tested before delivery", "Written warranty on all work"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`,
    img: "https://images.pexels.com/photos/8985465/pexels-photo-8985465.jpeg?auto=compress&cs=tinysrgb&w=800",
    imgAlt: "Mechanic working on a car engine in a professional shop",
  },
  {
    href: "/services/driveline",
    name: "Driveline Services",
    tagline: "That vibration at highway speed isn't going away on its own.",
    desc: "Driveline problems get worse with every mile. We diagnose and repair your complete driveline — U-joints, driveshafts, axles, differentials — so your vehicle runs smooth.",
    bullets: ["Driveshaft inspection and balancing", "U-joint replacement", "CV axle service", "Differential repair and rebuild", "Complete driveline diagnosis"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
    img: "https://images.pexels.com/photos/6870302/pexels-photo-6870302.jpeg?auto=compress&cs=tinysrgb&w=800",
    imgAlt: "Mechanic working under a car repairing the chassis and driveline",
  },
  {
    href: "/services/classic-cars",
    name: "Classic Car Transmissions",
    tagline: "Finding someone who actually knows vintage transmissions is hard.",
    desc: "Classic and muscle car transmissions are JP's specialty. Muncie 4-speeds, TH350s, TH400s — we've rebuilt them all. Most shops today turn away classic car work. We seek it out.",
    bullets: ["Muncie 4-speed rebuilds", "TH350 / TH400 rebuilds", "Ford C4 / C6 rebuilds", "Parts sourcing for discontinued units", "Period-correct rebuilds for show cars"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>`,
    img: "https://images.pexels.com/photos/28464228/pexels-photo-28464228.jpeg?auto=compress&cs=tinysrgb&w=800",
    imgAlt: "Classic American muscle car on display at a car show",
  },
  {
    href: "/services/manual-transmission",
    name: "Manual Transmission Service",
    tagline: "Hard shifting, grinding gears, or a clutch that won't release?",
    desc: "Most shops won't attempt a manual transmission rebuild. We rebuild manual transmissions that other shops turn away — foreign, domestic, classic, modern. All makes and models.",
    bullets: ["Complete manual trans rebuild", "Clutch inspection and replacement", "Shifter adjustment and repair", "NV4500, T56, Muncie, and more", "All makes and models"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/>`,
    img: "https://images.pexels.com/photos/91152/pexels-photo-91152.jpeg?auto=compress&cs=tinysrgb&w=800",
    imgAlt: "Close-up of a manual gear shift stick inside a vehicle",
  },
  {
    href: "/parts",
    name: "Parts Sales",
    tagline: "You've called six parts stores and nobody has what you need.",
    desc: "JP stocks and sources hard-to-find transmission and driveline components. 30 years of supplier relationships means he can find what others can't.",
    bullets: ["In-stock transmission components", "Differential and driveline parts", "Rebuild kits for all major units", "Classic and vintage car parts", "Nationwide shipping available"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>`,
    img: "https://images.pexels.com/photos/11157437/pexels-photo-11157437.jpeg?auto=compress&cs=tinysrgb&w=800",
    imgAlt: "Disassembled car transmission parts laid out on a workshop bench",
  },
  {
    href: "/services/diagnostics",
    name: "Free Diagnostics",
    tagline: "You don't want to spend $2,000 if a $200 repair will fix it.",
    desc: "We diagnose the real issue first. You get a straight answer and a straight quote before any work begins. No obligation to proceed.",
    bullets: ["Complete transmission inspection", "Road test and evaluation", "Computerized diagnostics", "Written quote before any work", "No obligation to proceed"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>`,
    img: "https://images.pexels.com/photos/6870332/pexels-photo-6870332.jpeg?auto=compress&cs=tinysrgb&w=800",
    imgAlt: "Mechanic using an automotive diagnostic tool beside a car",
  },
];
---

<Layout
  title="Transmission Services in Stratford, CT | JP Tadduni"
  description="Complete transmission rebuilds, driveline repair, and classic car transmission specialists in CT. Free quote — call today."
>

  <!-- Page header -->
  <section class="bg-jp-bg pt-12 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <span class="section-label">Expert Drivetrain Work</span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl md:text-6xl text-jp-charcoal leading-tight mb-4">
        Transmission &amp; Driveline Services
      </h1>
      <p class="font-body text-lg text-jp-muted max-w-2xl leading-relaxed">
        Complete rebuilds, repairs, and diagnostics for all makes and models.
        30+ years. Written warranty on every job.
      </p>
    </div>
  </section>

  <!-- Services blocks -->
  <div class="divide-y divide-jp-border">
    {services.map((service, i) => (
      <section class={`py-14 ${i % 2 === 0 ? 'bg-white' : 'bg-jp-bg'}`}>
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

            <!-- Left: Info -->
            <div>
              <div class="flex items-center gap-4 mb-5">
                <div class="w-12 h-12 flex items-center justify-center bg-jp-red rounded-full flex-shrink-0">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <Fragment set:html={service.icon} />
                  </svg>
                </div>
                <h2 class="font-heading font-bold text-2xl sm:text-3xl text-jp-charcoal leading-snug">{service.name}</h2>
              </div>
              <p class="font-body text-sm font-semibold text-jp-red uppercase tracking-wide mb-3">{service.tagline}</p>
              <p class="font-body text-jp-muted leading-relaxed mb-6">{service.desc}</p>
              <a href={phoneHref} class="btn-primary">Call For A Quote</a>
            </div>

            <!-- Right: Bullets + image placeholder -->
            <div class="flex flex-col gap-5">
              <div class="rounded-card overflow-hidden">
                <img
                  src={service.img}
                  alt={service.imgAlt}
                  class="w-full h-56 object-cover"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <ul class="flex flex-col gap-3">
                {service.bullets.map(bullet => (
                  <li class="flex items-center gap-3 font-body text-sm text-jp-text">
                    <svg class="w-4 h-4 text-jp-red flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {bullet}
                  </li>
                ))}
              </ul>
            </div>

          </div>
        </div>
      </section>
    ))}
  </div>

  <CTABanner />

</Layout>
