---
import Layout from '../layouts/Layout.astro';
const phone = "(860) 717-3158";
const phoneHref = "tel:+18607173158";
---
<Layout title="Thank You | JP Tadduni Transmissions & Driveline" description="Thank you for contacting JP Tadduni Transmissions. We'll call you within 1 business hour.">
  <section class="min-h-screen flex items-center justify-center py-20 bg-jp-bg">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <div class="w-20 h-20 mx-auto mb-8 bg-jp-red rounded-full flex items-center justify-center">
        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl text-jp-charcoal leading-tight mb-4">
        Got It. We'll Call You<br /><span class="text-jp-red">Within 1 Business Hour.</span>
      </h1>
      <p class="font-body text-jp-muted text-lg leading-relaxed mb-10">JP or a member of our team will call you at the number you provided. In the meantime, call us directly at {phone}.</p>
      <div class="jp-card text-left mb-10">
        <h2 class="font-heading font-bold text-xl text-jp-charcoal mb-5">What happens next:</h2>
        <div class="flex flex-col gap-4">
          {[
            { step: "1", text: "We'll call you within 1 business hour (Mon–Fri 8am–5pm, Sat 8am–1pm)." },
            { step: "2", text: "We'll ask a few more questions about your vehicle and the symptoms." },
            { step: "3", text: "We'll give you an honest assessment and schedule a time to bring the car in." },
            { step: "4", text: "After diagnosis, you get a complete written quote before any work begins." },
          ].map(item => (
            <div class="flex items-start gap-4">
              <span class="w-8 h-8 flex-shrink-0 flex items-center justify-center bg-jp-red text-white font-heading font-bold text-sm rounded-full">{item.step}</span>
              <p class="font-body text-jp-muted text-sm leading-relaxed pt-1">{item.text}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="mb-10 font-body text-sm text-jp-muted">
        <p class="font-semibold text-jp-charcoal mb-2">Shop Hours</p>
        <p>Monday – Friday: 8:00 AM – 5:00 PM</p>
        <p>Saturday: 8:00 AM – 1:00 PM · Sunday: Closed</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={phoneHref} class="btn-primary">Call Now: {phone}</a>
        <a href="/" class="btn-secondary">Back to Home</a>
      </div>
    </div>
  </section>
</Layout>
