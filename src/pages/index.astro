---
/**
 * index.astro – JP Tadduni Transmissions & Driveline Homepage
 *
 * Section order (conversion-optimized):
 *   Hero → PainSection → PromiseSection → Services → ProofBar →
 *   ServiceAreas → PartsPreview → FAQ → CTABanner
 */

import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import PainSection from '../components/sections/PainSection.astro';
import PromiseSection from '../components/sections/PromiseSection.astro';
import Services from '../components/sections/Services.astro';
import ProofBar from '../components/sections/ProofBar.astro';
import ServiceAreas from '../components/sections/ServiceAreas.astro';
import PartsPreview from '../components/sections/PartsPreview.astro';
import FAQ from '../components/sections/FAQ.astro';
import CTABanner from '../components/sections/CTABanner.astro';

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  "name": "JP Tadduni Transmissions & Driveline",
  "description":
    "Stratford, Connecticut's transmission rebuild and driveline specialists. Expert transmission rebuilds, driveline services, classic car transmission specialists, manual transmissions, parts sales, and diagnostics. 30+ years experience. All makes and models. Written warranty.",
  "telephone": "(203) 375-1700",
  "url": "https://jptaddunitransmissions.com",
  "priceRange": "$$",
  "foundingDate": "1995",
  "slogan": "Transmissions Rebuilt Right. Warranted.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Stratford",
    "addressRegion": "CT",
    "postalCode": "06615",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "41.1843",
    "longitude": "-73.1332"
  },
  "areaServed": [
    "Stratford", "Bridgeport", "Milford", "New Haven",
    "Fairfield", "Trumbull", "Shelton", "Derby",
    "Ansonia", "Naugatuck", "Waterbury", "Meriden",
    "Hartford", "Greenwich", "Stamford", "Norwalk", "Danbury"
  ].map(city => ({ "@type": "City", "name": city })),
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Transmission & Driveline Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Transmission Rebuild" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Driveline Services" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Classic Car Transmissions" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Manual Transmission Service" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Parts Sales" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Transmission Diagnostics" } }
    ]
  },
  "knowsAbout": [
    "transmission rebuild", "driveline service", "classic car transmission",
    "manual transmission repair", "automatic transmission rebuild",
    "Connecticut transmission shop", "Stratford CT auto repair"
  ]
});
---

<Layout
  title="Transmission Rebuild & Driveline Service in Stratford, CT | JP Tadduni Transmissions"
  description="JP Tadduni rebuilds transmissions right the first time — with a written warranty. Stratford, CT's specialist for all makes, models, and classic cars. Free diagnosis."
  schema={localBusinessSchema}
>
  <Hero />
  <PainSection />
  <PromiseSection />
  <Services />
  <ProofBar />
  <ServiceAreas />
  <PartsPreview />
  <FAQ />
  <CTABanner />
</Layout>
