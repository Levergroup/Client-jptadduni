---
/**
 * index.astro – JP Tadduni Transmissions & Driveline Homepage
 * Light theme redesign. Section order:
 * Hero → TrustBar → PainSection → Services → PartsPreview → ServiceAreas → FAQ → CTABanner
 */

import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import PainSection from '../components/sections/PainSection.astro';
import Services from '../components/sections/Services.astro';
import PartsPreview from '../components/sections/PartsPreview.astro';
import ServiceAreas from '../components/sections/ServiceAreas.astro';
import FAQ from '../components/sections/FAQ.astro';
import CTABanner from '../components/sections/CTABanner.astro';

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  "name": "JP Tadduni Transmissions & Driveline",
  "description": "Stratford, Connecticut's transmission rebuild and driveline specialists. 30+ years experience. All makes and models. Written warranty.",
  "telephone": "(475) XXX-XXXX",
  "url": "https://jptaddunitransmissions.com",
  "priceRange": "$$",
  "foundingDate": "1995",
  "slogan": "Transmissions Rebuilt Right. Warranted.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "480 Surf Ave",
    "addressLocality": "Stratford",
    "addressRegion": "CT",
    "postalCode": "06615",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "41.1843",
    "longitude": "-73.1332"
  },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "08:00", "closes": "17:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "13:00" }
  ],
  "areaServed": [
    "Stratford","Bridgeport","Milford","New Haven","Fairfield","Trumbull",
    "Shelton","Derby","Ansonia","Naugatuck","Waterbury","Meriden","Hartford",
    "Greenwich","Stamford","Norwalk","Danbury","Westport","Darien",
    "New Canaan","Wilton","Ridgefield","Bethel","Newtown","Monroe"
  ].map(city => ({ "@type": "City", "name": city })),
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Transmission & Driveline Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Transmission Rebuild" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Driveline Services" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Classic Car Transmissions" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Manual Transmission Service" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Parts Sales" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Free Diagnostics" } }
    ]
  }
});
---

<Layout
  title="JP Tadduni Transmissions & Driveline | Stratford, CT Transmission Specialists"
  description="CT's trusted transmission rebuild specialists. All makes, all models. Free diagnosis. Written warranty. Call JP in Stratford today."
  schema={localBusinessSchema}
>
  <Hero />
  <TrustBar />
  <PainSection />
  <Services />
  <PartsPreview />
  <ServiceAreas />
  <FAQ />

  <!-- Location & Map -->
  <section class="py-14 bg-jp-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <!-- Info -->
        <div class="flex flex-col gap-5">
          <div>
            <span class="section-label">Find Us</span>
            <h2 class="section-title">Visit Our Shop</h2>
            <p class="section-sub">Come in for a free diagnosis — no appointment needed during business hours.</p>
          </div>
          <div class="flex flex-col gap-4">
            <div class="jp-card flex items-start gap-4">
              <svg class="w-5 h-5 text-jp-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <div>
                <p class="font-heading font-semibold text-jp-charcoal">Address</p>
                <p class="font-body text-jp-muted text-sm">480 Surf Ave, Stratford, CT 06615</p>
              </div>
            </div>
            <div class="jp-card flex items-start gap-4">
              <svg class="w-5 h-5 text-jp-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <div>
                <p class="font-heading font-semibold text-jp-charcoal">Hours</p>
                <p class="font-body text-jp-muted text-sm">Mon–Fri: 8:00 AM – 5:00 PM</p>
                <p class="font-body text-jp-muted text-sm">Saturday: 8:00 AM – 1:00 PM</p>
                <p class="font-body text-jp-muted text-sm">Sunday: Closed</p>
              </div>
            </div>
            <div class="jp-card flex items-start gap-4">
              <svg class="w-5 h-5 text-jp-red flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
              <div>
                <p class="font-heading font-semibold text-jp-charcoal">Phone</p>
                <a href="tel:+14750000000" class="font-body text-jp-red font-semibold text-sm hover:text-red-700 transition-colors">(475) XXX-XXXX</a>
              </div>
            </div>
          </div>
        </div>
        <!-- Map -->
        <div class="rounded-card overflow-hidden shadow-card h-80 lg:h-full min-h-[320px]">
          <iframe
            src="https://maps.google.com/maps?q=480+Surf+Ave,+Stratford,+CT+06615&output=embed"
            width="100%"
            height="100%"
            style="border:0; min-height:320px;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="JP Tadduni Transmissions location — 480 Surf Ave, Stratford CT"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>
