---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import TrustBar from '../components/sections/TrustBar.astro';
const values = [
  { title: "Diagnose First", body: "We never start work until we know exactly what's wrong. You get a complete, honest assessment before you spend a dollar." },
  { title: "Rebuild Right", body: "A transmission rebuild means tearing the unit completely down. Every component inspected, measured, and rebuilt to factory specification." },
  { title: "Quote Straight", body: "We give you a complete quote before any work begins. No upsells after teardown, no surprise invoices. What we quote is what you pay." },
  { title: "Warrant the Work", body: "Every rebuild we complete comes with a written warranty. We stand behind our work — because we're confident in every job." },
];
---
<Layout title="About JP Tadduni Transmissions & Driveline | Stratford, CT" description="JP Tadduni Transmissions — Stratford, CT's transmission rebuild specialist. 30+ years. Family owned. All makes and models. Written warranty.">

  <section class="bg-jp-bg pt-12 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <span class="section-label">Our Story</span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl md:text-6xl text-jp-charcoal leading-tight mb-6">
        30+ Years.<br /><span class="text-jp-red">Built on Precision &amp; Trust.</span>
      </h1>
      <p class="font-body text-jp-muted text-lg max-w-2xl leading-relaxed">JP Tadduni Transmissions & Driveline has been Stratford, Connecticut's go-to transmission specialist for over three decades. Family owned. Connecticut based.</p>
    </div>
  </section>

  <TrustBar />

  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="flex flex-col gap-5 font-body text-jp-muted leading-relaxed">
          <p class="text-jp-charcoal text-lg font-semibold">JP Tadduni didn't set out to build a business. He set out to build transmissions right.</p>
          <p>What started as a deep passion for mechanical precision became one of Connecticut's most trusted drivetrain shops. For over 30 years, JP Tadduni Transmissions & Driveline has served customers from Stratford to Stamford, New Haven to Hartford — and from across the country via shipped transmission work.</p>
          <p>The shop has stayed family owned by design. There's no corporate management layer between you and the people doing the work. When you call JP Tadduni, you talk to someone who actually knows transmissions.</p>
          <p>We specialize in what other shops avoid: complete transmission rebuilds, classic car drivetrains, manual transmissions, and hard-to-find parts.</p>
          <p class="text-jp-charcoal font-semibold">Every transmission that leaves our shop has a written warranty. Not because we're required to — because we're confident in every job we complete.</p>
        </div>
        <div class="flex flex-col gap-4">
          {[
            { label: "Founded", value: "1995", sub: "Over 30 years in business" },
            { label: "Location", value: "Stratford, CT", sub: "Serving all of Connecticut" },
            { label: "Specialty", value: "Transmission Rebuild", sub: "And all driveline services" },
            { label: "Experience", value: "All Makes & Models", sub: "Including classic cars" },
            { label: "Guarantee", value: "Written Warranty", sub: "On every rebuild" },
            { label: "Nationwide", value: "Ship-In Service", sub: "We accept shipped transmissions" },
          ].map(fact => (
            <div class="jp-card flex items-center gap-5 border-l-4 border-jp-red">
              <div>
                <span class="font-body text-xs uppercase tracking-widest text-jp-muted">{fact.label}</span>
                <p class="font-heading font-bold text-lg text-jp-charcoal leading-tight">{fact.value}</p>
                <p class="font-body text-xs text-jp-muted">{fact.sub}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20 bg-jp-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <span class="section-label">How We Work</span>
        <h2 class="section-title">Four Things We Never Compromise On</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {values.map((val, i) => (
          <div class="jp-card flex flex-col gap-3">
            <span class="font-heading font-bold text-5xl leading-none text-jp-red" style="opacity:0.2">0{i + 1}</span>
            <h3 class="font-heading font-bold text-xl text-jp-charcoal">{val.title}</h3>
            <p class="font-body text-jp-muted leading-relaxed text-sm">{val.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>
