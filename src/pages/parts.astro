---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/sections/CTABanner.astro';

const phone = "(475) XXX-XXXX";
const phoneHref = "tel:+14750000000";

const categories = [
  {
    name: "Manual Transmission Units",
    parts: [
      { name: "Muncie 4-Speed (M20/M21/M22)", cat: "Classic Car Parts", desc: "Complete units and components for GM muscle car applications. All ratios available.", img: "https://images.pexels.com/photos/3642618/pexels-photo-3642618.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Close-up of classic manual transmission automotive part" },
      { name: "T56 Magnum 6-Speed", cat: "Manual Transmissions", desc: "Tremec T56 Magnum units and parts for high performance builds.", img: "https://images.pexels.com/photos/11526277/pexels-photo-11526277.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Close-up of a 6-speed manual gearbox unit" },
      { name: "Ford Toploader 4-Speed", cat: "Classic Car Parts", desc: "3.00 and 2.78 first gear ratio units and components.", img: "https://images.pexels.com/photos/8985510/pexels-photo-8985510.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Mechanic working on a classic transmission unit" },
      { name: "NV4500 Manual Parts", cat: "Manual Transmissions", desc: "Parts and rebuild kits for GM and Dodge NV4500 5-speed manuals.", img: "https://images.pexels.com/photos/8478225/pexels-photo-8478225.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Close-up of manual transmission components being serviced" },
    ],
  },
  {
    name: "Automatic Transmission Parts",
    parts: [
      { name: "TH350 / TH400 Parts", cat: "Transmission Units", desc: "Rebuild kits, hard parts, and complete units for GM automatics.", img: "https://images.pexels.com/photos/8985714/pexels-photo-8985714.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Mechanic working on an automatic transmission" },
      { name: "700R4 / 4L60E Parts", cat: "Transmission Units", desc: "Full rebuild kits and hard parts for GM overdrive transmissions.", img: "https://images.pexels.com/photos/8985601/pexels-photo-8985601.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Automatic transmission repair in a professional shop" },
      { name: "Ford C4 / C6 Parts", cat: "Transmission Units", desc: "Rebuild kits and components for classic Ford automatics.", img: "https://images.pexels.com/photos/8478231/pexels-photo-8478231.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Mechanic inspecting transmission components" },
      { name: "Torque Converters", cat: "Transmission Units", desc: "Stock replacement and performance torque converters for automatic transmissions.", img: "https://images.pexels.com/photos/11157437/pexels-photo-11157437.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Disassembled automatic transmission parts including torque converter" },
    ],
  },
  {
    name: "Differential & Driveline Parts",
    parts: [
      { name: "Positraction Units", cat: "Differential Parts", desc: "Limited slip differentials for GM 10-bolt and 12-bolt rear axle applications.", img: "https://images.pexels.com/photos/159275/pexels-photo-159275.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Close-up of precision automotive gears — positraction differential" },
      { name: "Ring & Pinion Sets", cat: "Ring & Pinion", desc: "Gear sets for GM, Ford, and Chrysler rear axle applications. Multiple ratios.", img: "https://images.pexels.com/photos/221028/pexels-photo-221028.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Grayscale close-up of interlocking ring and pinion gears" },
      { name: "Differential Rebuild Kits", cat: "Rebuild Kits", desc: "Master rebuild kits for GM, Ford, and Chrysler differentials.", img: "https://images.pexels.com/photos/159298/pexels-photo-159298.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Mechanical gear set for differential rebuild kit" },
      { name: "Transmission Coolers", cat: "Cooling", desc: "External transmission coolers for towing and performance applications.", img: "https://images.pexels.com/photos/1819668/pexels-photo-1819668.jpeg?auto=compress&cs=tinysrgb&w=600", imgAlt: "Automotive cooling radiator for transmission cooler" },
    ],
  },
];
---

<Layout
  title="Transmission & Driveline Parts | JP Tadduni Stratford CT"
  description="Hard-to-find transmission and driveline parts. Positraction, ring & pinion, Muncie 4-speed and more. Call JP today."
>

  <!-- Hero -->
  <section class="bg-jp-bg pt-12 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <span class="section-label">Parts Sales</span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl md:text-6xl text-jp-charcoal leading-tight mb-6">
        Hard-to-Find Parts.<br /><span class="text-jp-red">We Stock &amp; Source Them.</span>
      </h1>
      <p class="font-body text-jp-muted text-lg max-w-2xl leading-relaxed mb-8">
        From classic muscle car transmissions to late-model solenoid kits and ring & pinion sets — JP Tadduni stocks and sources drivetrain components that most parts stores have never heard of.
      </p>
      <!-- Red callout -->
      <div class="inline-flex items-center gap-3 bg-jp-red text-white px-6 py-4 rounded-card">
        <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
        <span class="font-body font-semibold text-sm">For pricing and availability call JP directly: <strong>{phone}</strong></span>
      </div>
    </div>
  </section>

  <!-- Parts grid -->
  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col gap-14">
        {categories.map(cat => (
          <div>
            <h2 class="font-heading font-bold text-2xl text-jp-charcoal border-b-2 border-jp-red pb-3 mb-6 uppercase tracking-wide">
              {cat.name}
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
              {cat.parts.map(part => (
                <div class="parts-card flex flex-col gap-3">
                  <!-- Part photo -->
                  <div class="w-full rounded-md overflow-hidden">
                    <img
                      src={part.img}
                      alt={part.imgAlt}
                      class="w-full h-44 object-cover"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <span class="inline-block text-xs font-semibold uppercase tracking-wider text-jp-red bg-red-50 px-2 py-1 rounded self-start">{part.cat}</span>
                  <h3 class="font-heading font-bold text-base text-jp-charcoal">{part.name}</h3>
                  <p class="font-body text-jp-muted text-sm leading-relaxed flex-1">{part.desc}</p>
                  <a href="/contact" class="btn-primary text-sm py-2.5 justify-center text-center mt-auto">Inquire About This Part →</a>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>
