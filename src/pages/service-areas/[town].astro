---
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/sections/CTABanner.astro';

export function getStaticPaths() {
  const towns = [
    { slug: "stratford",   name: "Stratford",   county: "Fairfield" },
    { slug: "bridgeport",  name: "Bridgeport",  county: "Fairfield" },
    { slug: "milford",     name: "Milford",      county: "New Haven" },
    { slug: "new-haven",   name: "New Haven",    county: "New Haven" },
    { slug: "fairfield",   name: "Fairfield",    county: "Fairfield" },
    { slug: "trumbull",    name: "Trumbull",     county: "Fairfield" },
    { slug: "shelton",     name: "Shelton",      county: "Fairfield" },
    { slug: "derby",       name: "Derby",        county: "New Haven" },
    { slug: "ansonia",     name: "Ansonia",      county: "New Haven" },
    { slug: "naugatuck",   name: "Naugatuck",    county: "New Haven" },
    { slug: "waterbury",   name: "Waterbury",    county: "New Haven" },
    { slug: "meriden",     name: "Meriden",      county: "New Haven" },
    { slug: "hartford",    name: "Hartford",     county: "Hartford"  },
    { slug: "greenwich",   name: "Greenwich",    county: "Fairfield" },
    { slug: "stamford",    name: "Stamford",     county: "Fairfield" },
    { slug: "norwalk",     name: "Norwalk",      county: "Fairfield" },
    { slug: "danbury",     name: "Danbury",      county: "Fairfield" },
    { slug: "westport",    name: "Westport",     county: "Fairfield" },
    { slug: "darien",      name: "Darien",       county: "Fairfield" },
    { slug: "new-canaan",  name: "New Canaan",   county: "Fairfield" },
    { slug: "wilton",      name: "Wilton",       county: "Fairfield" },
    { slug: "ridgefield",  name: "Ridgefield",   county: "Fairfield" },
    { slug: "bethel",      name: "Bethel",       county: "Fairfield" },
    { slug: "newtown",     name: "Newtown",      county: "Fairfield" },
    { slug: "monroe",      name: "Monroe",       county: "Fairfield" },
  ];
  return towns.map(town => ({ params: { town: town.slug }, props: { town } }));
}

const { town } = Astro.props;
const phone = "(475) XXX-XXXX";
const phoneHref = "tel:+14750000000";

const localServiceSchema = JSON.stringify({
  "@context": "https://schema.org", "@type": "Service",
  "name": `Transmission Rebuild in ${town.name}, CT`,
  "description": `JP Tadduni Transmissions & Driveline provides expert transmission rebuild and driveline services to ${town.name}, Connecticut.`,
  "provider": { "@type": "AutoRepair", "name": "JP Tadduni Transmissions & Driveline", "telephone": "(475) XXX-XXXX",
    "address": { "@type": "PostalAddress", "addressLocality": "Stratford", "addressRegion": "CT", "postalCode": "06615" }
  },
  "areaServed": { "@type": "City", "name": town.name, "containedInPlace": { "@type": "State", "name": "Connecticut" } }
});

const services = [
  { name: "Transmission Rebuild", href: "/services/transmission-rebuild" },
  { name: "Driveline Services", href: "/services/driveline" },
  { name: "Classic Car Specialists", href: "/services/classic-cars" },
  { name: "Manual Transmissions", href: "/services/manual-transmission" },
  { name: "Parts Sales", href: "/parts" },
  { name: "Free Diagnostics", href: "/services/diagnostics" },
];
---
<Layout
  title={`Transmission Rebuild in ${town.name}, CT | JP Tadduni Transmissions`}
  description={`Transmission repair and rebuild service for ${town.name}, CT. JP Tadduni rebuilds it right — all makes, all models. Free diagnosis. Written warranty. Call today.`}
  schema={localServiceSchema}
>

  <section class="bg-jp-bg pt-12 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="flex items-center gap-2 text-xs text-jp-muted mb-6 font-body uppercase tracking-widest">
        <a href="/" class="hover:text-jp-red transition-colors">Home</a><span>/</span>
        <a href="/service-areas" class="hover:text-jp-red transition-colors">Service Areas</a><span>/</span>
        <span class="text-jp-charcoal font-semibold">{town.name}</span>
      </nav>
      <span class="section-label">Serving {town.name}, CT</span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl md:text-6xl text-jp-charcoal leading-tight mb-6">
        Transmission Rebuild &amp;<br />
        Driveline Service in<br />
        <span class="text-jp-red">{town.name}, CT</span>
      </h1>
      <p class="font-body text-jp-muted text-lg max-w-2xl leading-relaxed mb-8">
        JP Tadduni Transmissions & Driveline serves {town.name} and all of {town.county} County.
        Expert transmission rebuilds, driveline service, and classic car specialists.
        All makes and models. Free diagnosis. Written warranty.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={phoneHref} class="btn-primary">Call Now: {phone}</a>
        <a href="/contact" class="btn-secondary">Get A Free Quote →</a>
      </div>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <div>
          <span class="section-label">Services Available in {town.name}</span>
          <h2 class="section-title mb-6">We Come to You.<br /><span class="text-jp-red">Or You Come to Us.</span></h2>
          <p class="font-body text-jp-muted leading-relaxed mb-4">
            Whether you're driving your vehicle to our Stratford shop or need advice before bringing it in, JP Tadduni serves {town.name} residents with the same precision and honesty we've built our reputation on for over 30 years.
          </p>
          <p class="font-body text-jp-muted leading-relaxed mb-8">
            We also accept shipped transmissions — so if you're working on a project car and need a specific unit rebuilt, we can handle that too.
          </p>
          <div class="flex flex-col gap-1">
            {services.map(service => (
              <a href={service.href} class="flex items-center gap-3 py-3 border-b border-jp-border hover:text-jp-red group transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-jp-red flex-shrink-0"></span>
                <span class="font-body text-sm text-jp-text group-hover:text-jp-red transition-colors">{service.name}</span>
                <svg class="w-4 h-4 text-jp-muted ml-auto group-hover:text-jp-red group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            ))}
          </div>
        </div>

        <div class="flex flex-col gap-5">
          <div class="jp-card border-l-4 border-jp-red">
            <h3 class="font-heading font-bold text-xl text-jp-charcoal mb-4">Serving {town.name} from Our Stratford Shop</h3>
            <div class="flex flex-col gap-3 font-body text-sm">
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-jp-red mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                <span class="text-jp-muted">Stratford, CT 06615 — serving all of {town.county} County</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-jp-red mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
                <a href={phoneHref} class="text-jp-red font-semibold hover:text-jp-red-dark transition-colors">{phone}</a>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-jp-red mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-jp-muted">Mon–Fri 8am–5pm · Sat 8am–1pm</span>
              </div>
            </div>
            <div class="mt-5 pt-5 border-t border-jp-border">
              <a href="/contact" class="btn-primary w-full justify-center text-sm">Schedule Service →</a>
            </div>
          </div>

          <div class="flex flex-col gap-1 text-xs font-body uppercase tracking-widest text-jp-muted">
            {["Free diagnosis — no obligation","All makes and models","Classic car specialists","Written warranty on every rebuild","30+ years experience"].map(item => (
              <span class="flex items-center gap-2 py-2 border-b border-jp-border last:border-0">
                <svg class="w-3.5 h-3.5 text-jp-red flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {item}
              </span>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <CTABanner />
</Layout>
