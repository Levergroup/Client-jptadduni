---
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/sections/CTABanner.astro';
import FAQ from '../../components/sections/FAQ.astro';

const phone = "(860) 717-3158";
const phoneHref = "tel:+18607173158";

const process = [
  { step: "01", title: "Drop-Off & Diagnosis", body: "We road test and perform a full diagnostic before any teardown. You'll know what's wrong before we quote a dollar." },
  { step: "02", title: "Complete Disassembly", body: "The transmission comes completely out and apart. Every component goes on the bench for inspection." },
  { step: "03", title: "Inspect & Measure", body: "Every component is inspected against factory spec. Worn, scored, or out-of-spec parts get flagged." },
  { step: "04", title: "Rebuild to Spec", body: "New seals, clutch packs, bushings, and bearings. Solenoids tested, valve body cleaned. Everything rebuilt to OEM tolerances." },
  { step: "05", title: "Reassemble & Test", body: "The unit goes back together with precision torque specs, then pressure tested on the bench before it touches your car." },
  { step: "06", title: "Road Test & Warranty", body: "Final road test covers all gear ranges under load. You drive away with a written warranty." },
];

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org", "@type": "Service",
  "name": "Transmission Rebuild", "serviceType": "Transmission Rebuild",
  "provider": { "@type": "AutoRepair", "name": "JP Tadduni Transmissions & Driveline", "telephone": "(860) 717-3158",
    "address": { "@type": "PostalAddress", "addressLocality": "Stratford", "addressRegion": "CT", "postalCode": "06615" }
  },
  "areaServed": { "@type": "State", "name": "Connecticut" }
});
---
<Layout title="Transmission Rebuild in Stratford, CT | JP Tadduni Transmissions" description="Complete transmission rebuild — tear-down to factory spec — for all makes and models. Stratford, CT. Free diagnosis. Written warranty. 30+ years." schema={serviceSchema}>

  <section class="bg-jp-bg pt-12 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="flex items-center gap-2 text-xs text-jp-muted mb-6 font-body uppercase tracking-widest">
        <a href="/" class="hover:text-jp-red transition-colors">Home</a><span>/</span>
        <a href="/services" class="hover:text-jp-red transition-colors">Services</a><span>/</span>
        <span class="text-jp-charcoal font-semibold">Transmission Rebuild</span>
      </nav>
      <span class="section-label">Stratford, CT</span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl md:text-6xl text-jp-charcoal leading-tight mb-6">
        Transmission Rebuild<br /><span class="text-jp-red">Done Right. Warranted.</span>
      </h1>
      <p class="font-body text-jp-muted text-lg max-w-2xl leading-relaxed mb-8">
        Slipping gears, no movement, grinding, delayed engagement — JP Tadduni tears it completely down, rebuilds every component to factory spec, and backs it with a written warranty.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={phoneHref} class="btn-primary">Call For A Free Quote</a>
        <a href="/contact" class="btn-secondary">Request A Quote Online →</a>
      </div>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <span class="section-label">The Difference</span>
          <h2 class="section-title mb-6">Parts-Swap vs. Real Rebuild.<br /><span class="text-jp-red">There's No Contest.</span></h2>
          <div class="flex flex-col gap-4 font-body text-jp-muted leading-relaxed">
            <p>Any shop can pull your transmission, drop in a used one from a junkyard, and call it fixed. You'll drive away happy — for 18 months. Then the cycle starts again.</p>
            <p>A real rebuild means the unit comes completely apart. Every component inspected and measured against factory tolerances. Worn parts replaced. Solenoids tested. Valve body cleaned. Seals and gaskets replaced throughout. Then reassembled to spec and pressure tested.</p>
            <p class="text-jp-charcoal font-semibold">That's the JP Tadduni way — and that's why we back every rebuild with a written warranty.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { label: "Automatic Transmissions", sub: "All domestic and import units" },
            { label: "Manual Transmissions", sub: "Synchros, bearings, and gear sets" },
            { label: "Transfer Cases", sub: "4WD and AWD applications" },
            { label: "Torque Converters", sub: "Rebuild and replacement" },
            { label: "All Makes & Models", sub: "From daily drivers to classics" },
            { label: "Written Warranty", sub: "Every rebuild, every time" },
          ].map(item => (
            <div class="jp-card">
              <h3 class="font-heading font-bold text-jp-charcoal text-base mb-1">{item.label}</h3>
              <p class="font-body text-jp-muted text-xs">{item.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 bg-jp-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <span class="section-label">The Process</span>
        <h2 class="section-title">How We Rebuild Your Transmission</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {process.map(step => (
          <div class="jp-card flex flex-col gap-3">
            <span class="font-heading font-bold text-4xl leading-none text-jp-red" style="opacity:0.25">{step.step}</span>
            <h3 class="font-heading font-bold text-xl text-jp-charcoal">{step.title}</h3>
            <p class="font-body text-jp-muted text-sm leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ />
  <CTABanner />
</Layout>
