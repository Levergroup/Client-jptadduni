---
/**
 * transmission-rebuild.astro – Transmission Rebuild service page for JP Tadduni.
 */

import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/sections/CTABanner.astro';
import FAQ from '../../components/sections/FAQ.astro';

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Transmission Rebuild",
  "description": "Complete automatic and manual transmission rebuild service in Stratford, CT. All makes and models. Written warranty.",
  "provider": {
    "@type": "AutoRepair",
    "name": "JP Tadduni Transmissions & Driveline",
    "telephone": "(203) 375-1700",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Stratford",
      "addressRegion": "CT",
      "postalCode": "06615"
    }
  },
  "areaServed": { "@type": "State", "name": "Connecticut" },
  "serviceType": "Transmission Rebuild",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Transmission Rebuild Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Automatic Transmission Rebuild" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Manual Transmission Rebuild" } }
    ]
  }
});

const process = [
  { step: "01", title: "Drop-Off & Diagnosis", body: "We road test the vehicle and perform a full diagnostic before any teardown begins. You'll know what's wrong before we quote a single dollar." },
  { step: "02", title: "Complete Disassembly", body: "The transmission comes completely out and apart. Every component — case, drums, clutch packs, bands, solenoids, pump — goes on the bench." },
  { step: "03", title: "Inspect & Measure", body: "Every component is inspected against factory spec. Worn drums, scored surfaces, and out-of-spec clutch packs get flagged. Nothing gets guessed." },
  { step: "04", title: "Rebuild to Spec", body: "New seals, O-rings, clutch packs, bushings, and bearings. Solenoids tested, valve body cleaned and inspected. Everything rebuilt to OEM tolerances." },
  { step: "05", title: "Reassemble & Test", body: "The unit goes back together with precision torque specs. Then it gets pressure tested on the bench before it goes anywhere near your car." },
  { step: "06", title: "Road Test & Warranty", body: "Final road test covers all gear ranges under load. You drive away with a written warranty — because a real rebuild should last 100,000 miles." },
];
---

<Layout
  title="Transmission Rebuild in Stratford, CT | JP Tadduni Transmissions"
  description="Complete transmission rebuild — tear-down to factory spec — for all makes and models. Stratford, CT. Free diagnosis. Written warranty. 30+ years experience."
  schema={serviceSchema}
>

  <!-- Hero -->
  <section class="relative pt-24 pb-16 bg-jp-black overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse at 70% 50%, rgba(204,0,0,0.1) 0%, transparent 60%);"
      aria-hidden="true"
    ></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
      <nav class="flex items-center gap-2 text-xs text-jp-muted mb-8 font-body uppercase tracking-widest">
        <a href="/" class="hover:text-jp-gray transition-colors">Home</a>
        <span>/</span>
        <a href="/services" class="hover:text-jp-gray transition-colors">Services</a>
        <span>/</span>
        <span class="text-jp-chrome">Transmission Rebuild</span>
      </nav>
      <p class="font-body text-xs font-semibold tracking-[0.25em] uppercase text-jp-red mb-4">Stratford, CT</p>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl md:text-6xl text-jp-white leading-tight mb-6">
        Transmission Rebuild<br />
        <span class="text-jp-red">Done Right. Warranted.</span>
      </h1>
      <p class="font-body text-jp-muted text-lg max-w-2xl leading-relaxed mb-10">
        Slipping gears, no movement, grinding, delayed engagement — these aren't minor issues.
        Your transmission is failing. JP Tadduni tears it completely down, rebuilds every component
        to factory spec, and puts it back in your vehicle with a written warranty.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="btn-primary">Get Your Free Diagnosis →</a>
        <a href="tel:+12033751700" class="btn-secondary" style="animation: none;">Call (203) 375-1700</a>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Why a real rebuild matters -->
  <section class="py-20 bg-jp-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <p class="font-body text-xs font-semibold tracking-[0.25em] uppercase text-jp-red mb-4">The Difference</p>
          <h2 class="font-heading font-bold text-3xl sm:text-4xl text-jp-white leading-snug mb-6">
            Parts-Swap vs. Real Rebuild.<br />
            <span class="text-jp-chrome">There's No Contest.</span>
          </h2>
          <div class="flex flex-col gap-6 font-body text-jp-muted leading-relaxed">
            <p>Any shop can pull your transmission, drop in a used one from a junkyard, and call it fixed. You'll drive away happy — for 18 months. Then the cycle starts again.</p>
            <p>A real rebuild means the unit comes completely apart. Every single component is inspected and measured against factory tolerances. Worn parts get replaced. Solenoids get tested. Valve body cleaned. Seals and gaskets replaced throughout. Then it's reassembled to spec and pressure tested before it touches your car.</p>
            <p class="text-jp-white font-semibold">That's the JP Tadduni way. And that's why we back every rebuild with a written warranty.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { label: "Automatic Transmissions", sub: "All domestic and import units" },
            { label: "Manual Transmissions", sub: "Synchros, bearings, and gear sets" },
            { label: "Transfer Cases", sub: "4WD and AWD applications" },
            { label: "Torque Converters", sub: "Rebuild and replacement" },
            { label: "All Makes & Models", sub: "From daily drivers to classics" },
            { label: "Written Warranty", sub: "Every rebuild, every time" },
          ].map(item => (
            <div class="jp-card">
              <h3 class="font-heading font-bold text-jp-white text-base mb-1">{item.label}</h3>
              <p class="font-body text-jp-muted text-xs">{item.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-20 bg-jp-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-14">
        <p class="font-body text-xs font-semibold tracking-[0.25em] uppercase text-jp-red mb-3">The Process</p>
        <h2 class="font-heading font-bold text-3xl sm:text-4xl text-jp-white leading-tight">
          How We Rebuild Your Transmission
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px" style="background: rgba(255,255,255,0.04);">
        {process.map(step => (
          <div class="bg-jp-dark p-8 flex flex-col gap-4 hover:bg-jp-card transition-colors duration-200 group">
            <span class="font-heading font-bold text-4xl leading-none" style="color: rgba(204,0,0,0.25);">{step.step}</span>
            <h3 class="font-heading font-bold text-xl text-jp-white">{step.title}</h3>
            <p class="font-body text-jp-muted text-sm leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ />
  <CTABanner />

</Layout>
