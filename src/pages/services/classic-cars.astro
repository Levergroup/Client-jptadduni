---
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/sections/CTABanner.astro';

const phone = "(475) XXX-XXXX";
const phoneHref = "tel:+14750000000";

const transmissions = [
  { name: "Muncie 4-Speed", sub: "M20, M21, M22 Rock Crusher" },
  { name: "Turbo-Hydramatic 350", sub: "TH350, TH350C" },
  { name: "Turbo-Hydramatic 400", sub: "TH400, 3L80" },
  { name: "700R4 / 4L60", sub: "Overdrive upgrade builds" },
  { name: "Ford Toploader", sub: "3 and 4-speed units" },
  { name: "T10 4-Speed", sub: "Borg-Warner and Saginaw" },
  { name: "A833 4-Speed", sub: "Mopar 4-speed transmissions" },
  { name: "Powerglide", sub: "2-speed GM automatic" },
  { name: "Chrysler 727 TorqueFlite", sub: "A727 rebuilds" },
  { name: "Ford C4 / C6", sub: "Ford automatic rebuilds" },
  { name: "Saginaw 3 & 4-Speed", sub: "GM column and floor shift" },
  { name: "Custom Performance Builds", sub: "Stage kits, shift kits, high-stall converters" },
];

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org", "@type": "Service", "name": "Classic Car Transmission Specialist",
  "provider": { "@type": "AutoRepair", "name": "JP Tadduni Transmissions & Driveline", "telephone": "(475) XXX-XXXX",
    "address": { "@type": "PostalAddress", "addressLocality": "Stratford", "addressRegion": "CT" }
  },
  "areaServed": { "@type": "State", "name": "Connecticut" }
});
---
<Layout title="Classic Car Transmission Specialists in CT | JP Tadduni Transmissions" description="Vintage and muscle car transmission rebuilds in Stratford, CT. Muncie 4-speed, TH400, Toploader, T10, Powerglide, and more." schema={serviceSchema}>

  <section class="bg-jp-bg pt-12 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="flex items-center gap-2 text-xs text-jp-muted mb-6 font-body uppercase tracking-widest">
        <a href="/" class="hover:text-jp-red transition-colors">Home</a><span>/</span>
        <a href="/services" class="hover:text-jp-red transition-colors">Services</a><span>/</span>
        <span class="text-jp-charcoal font-semibold">Classic Car Specialists</span>
      </nav>
      <span class="section-label">Vintage &amp; Muscle Car Experts</span>
      <h1 class="font-heading font-bold text-4xl sm:text-5xl md:text-6xl text-jp-charcoal leading-tight mb-6">
        Classic Car Transmissions.<br /><span class="text-jp-red">Old Iron Deserves Expert Hands.</span>
      </h1>
      <p class="font-body text-jp-muted text-lg max-w-2xl leading-relaxed mb-8">
        Your '69 Camaro. Your '70 Chevelle. Your '67 Mustang fastback. These machines deserve more than a general shop that's never seen a Muncie Rock Crusher up close.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={phoneHref} class="btn-primary">Talk to a Classic Car Specialist</a>
        <a href="/contact" class="btn-secondary">Request A Quote →</a>
      </div>
    </div>
  </section>

  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start mb-16">
        <div>
          <span class="section-label">Why It Matters</span>
          <h2 class="section-title mb-6">Most Shops Have Never<br /><span class="text-jp-red">Seen These Units.</span></h2>
          <div class="flex flex-col gap-4 font-body text-jp-muted leading-relaxed">
            <p>Classic American transmissions — Muncies, Toploaders, TH400s — are entirely different animals from modern computer-controlled units. The tolerances, the shimming, the synchronizer fitting — it's a different craft.</p>
            <p>Most shops today specialize in modern vehicles and outsource or decline classic car work. JP Tadduni has been building these units for decades.</p>
            <p class="text-jp-charcoal font-semibold">Your investment deserves the shop that actually knows the work.</p>
          </div>
        </div>
        <div class="flex flex-col gap-4">
          {[
            { title: "Correct OEM Specs", body: "We rebuild to factory specifications — not close, not approximate. Correct." },
            { title: "Correct Parts", body: "We source correct NOS and quality reproduction parts when originals are unavailable." },
            { title: "Performance Options", body: "Shift kits, stage kits, close-ratio gear sets, high-stall converters for performance builds." },
            { title: "Decades of Experience", body: "We've seen every issue these transmissions develop. Nothing surprises us." },
          ].map(item => (
            <div class="jp-card border-l-4 border-jp-red">
              <h3 class="font-heading font-bold text-jp-charcoal text-lg mb-2">{item.title}</h3>
              <p class="font-body text-jp-muted text-sm leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 bg-jp-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <span class="section-label">What We Rebuild</span>
        <h2 class="section-title">Classic Transmissions We Specialize In</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {transmissions.map(trans => (
          <div class="jp-card hover:border-l-4 hover:border-jp-red transition-all duration-200">
            <h3 class="font-heading font-bold text-jp-charcoal text-base mb-1">{trans.name}</h3>
            <p class="font-body text-jp-muted text-xs">{trans.sub}</p>
          </div>
        ))}
      </div>
      <p class="font-body text-jp-muted text-sm mt-8">
        Don't see your transmission?
        <a href="/contact" class="text-jp-red hover:text-jp-red-dark font-semibold transition-colors"> Ask us — we've probably built it. →</a>
      </p>
    </div>
  </section>

  <CTABanner />
</Layout>
