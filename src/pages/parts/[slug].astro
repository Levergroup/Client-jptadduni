      "Performance shift kits and valve body upgrades available",
    ],
    compatible: [
      "1982–1992 GM cars and trucks (700R4)",
      "1992–2013 GM trucks / SUVs (4L60E)",
      "Camaro, Corvette, Firebird applications",
      "S10 / Blazer / Sonoma",
      "Full-size Chevy / GMC trucks and vans",
    ],
    img: "https://images.pexels.com/photos/8985601/pexels-photo-8985601.jpeg?auto=compress&cs=tinysrgb&w=900",
    imgAlt: "Automatic transmission repair in a professional transmission shop",
    related: ["th350-th400-parts", "torque-converters", "transmission-coolers"],
  },
  {
    slug: "ford-c4-c6-parts",
    name: "Ford C4 / C6 Parts",
    fullName: "Ford C4 / C6 Rebuild Parts",
    category: "Transmission Units",
    categoryGroup: "Automatic Transmission Parts",
    desc: "The Ford C4 and C6 are among the most reliable and rebuildable automatic transmissions ever built. The C4 is a lightweight 3-speed favored in Mustangs and small-block applications, while the C6 is Ford's heavy-duty workhorse used behind big-block engines and in trucks. We carry rebuild kits, hard parts, and valve body upgrades for both.",
    specs: [
      "C4: 3-speed, aluminum case, small-block applications",
      "C6: 3-speed, aluminum case, big-block and diesel",
      "Performance shift kits available for both",
      "C4 input shaft: 24-spline",
      "C6 input shaft: 26-spline",
      "Complete master rebuild kits in stock",
    ],
    compatible: [
      "1964–1981 Ford Mustang (C4 — small block)",
      "1967–1981 Ford Mustang (C6 — big block)",
      "1966–1981 Ford Fairlane / Torino",
      "1967–1991 Ford trucks (C6)",
      "1968–1979 Ford Bronco",
    ],
    img: "https://images.pexels.com/photos/8478231/pexels-photo-8478231.jpeg?auto=compress&cs=tinysrgb&w=900",
    imgAlt: "Mechanic inspecting Ford C4 automatic transmission components",
    related: ["ford-toploader-4-speed", "torque-converters", "transmission-coolers"],
  },
  {
    slug: "torque-converters",
    name: "Torque Converters",
    fullName: "Performance & OEM Torque Converters",
    category: "Transmission Units",
    categoryGroup: "Automatic Transmission Parts",
    desc: "A worn or wrong torque converter causes shudder, overheating, and poor performance. We carry stock replacement and performance torque converters for GM, Ford, and Chrysler automatic transmissions. Whether you need a direct OEM replacement or a stall-speed converter matched to your engine's power curve, we can help you spec the right unit.",
    specs: [
      "Stall speeds: 1,600–3,500+ RPM available",
      "Sizes: 9\", 10\", 11\", 12\" diameter",
      "GM, Ford, and Chrysler bolt patterns",
      "Lock-up and non-lock-up versions",
      "Performance billet covers available",
