  // ── Automatic Transmission Parts ──────────────────────────────────────
  {
    slug: "th350-th400-parts",
    name: "TH350 / TH400 Parts",
    fullName: "TH350 / TH400 Rebuild Parts",
    category: "Transmission Units",
    categoryGroup: "Automatic Transmission Parts",
    desc: "The Turbo-Hydramatic 350 and 400 are the backbone of GM automatic transmissions — used in virtually every performance and heavy-duty GM application for decades. We carry complete rebuild kits, clutch packs, hard parts, valve body kits, and complete remanufactured units. Whether it's a street rebuild or a performance race build, we have what you need.",
    specs: [
      "TH350: 3-speed, case length ~21.75\"",
      "TH400: 3-speed, case length ~24.4\"",
      "TH400 torque capacity: 450+ lb-ft (stock)",
      "Shift kits, performance valve bodies available",
      "Band adjustments and clutch packs in stock",
      "Complete master rebuild kits available",
