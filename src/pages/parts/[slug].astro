    compatible: [
      "TH350 / TH400 applications",
      "700R4 / 4L60E / 4L80E",
      "Ford C4 / C6 / AOD",
      "Chrysler 727 / 904 / A518",
      "Custom stall specs available on request",
    ],
    img: "https://images.pexels.com/photos/11157437/pexels-photo-11157437.jpeg?auto=compress&cs=tinysrgb&w=900",
    imgAlt: "Disassembled automatic transmission parts including torque converter",
    related: ["th350-th400-parts", "700r4-4l60e-parts", "transmission-coolers"],
  },

  // ── Differential & Driveline Parts ────────────────────────────────────
  {
    slug: "positraction-units",
    name: "Positraction Units",
    fullName: "Positraction Limited Slip Units",
    category: "Differential Parts",
    categoryGroup: "Differential & Driveline Parts",
    desc: "Positraction is GM's limited-slip differential system — one of the most sought-after options for classic muscle cars and performance builds. When one wheel loses traction, a posi unit transfers power to the wheel with grip. We carry new and rebuilt Positraction units for GM 10-bolt and 12-bolt rear axle applications, plus clutch packs and rebuild kits.",
    specs: [
      "GM 10-bolt: 7.5\", 8.2\", 8.5\" ring gear",
      "GM 12-bolt: 8.875\" ring gear",
      "Clutch-type limited slip design",
      "Preload and bias ratios available",
      "Clutch pack and spider gear service kits",
      "New units and rebuilt cores available",
    ],
    compatible: [
      "1964–1972 Chevelle / El Camino",
      "1967–1981 Camaro / Firebird",
      "1963–1979 Corvette (various axle ratios)",
      "1969–1972 Nova",
      "1967–1972 GM trucks (10-bolt)",
    ],
    img: "https://images.pexels.com/photos/159275/pexels-photo-159275.jpeg?auto=compress&cs=tinysrgb&w=900",
    imgAlt: "Close-up of precision positraction limited slip differential gears",
    related: ["ring-pinion-sets", "differential-rebuild-kits", "transmission-coolers"],
  },
  {
    slug: "ring-pinion-sets",
    name: "Ring & Pinion Sets",
    fullName: "Ring & Pinion Gear Sets",
    category: "Ring & Pinion",
    categoryGroup: "Differential & Driveline Parts",
    desc: "Changing your ring and pinion ratio is one of the most impactful performance modifications you can make — affecting acceleration, highway RPM, and towing capability. We carry gear sets for GM, Ford, and Chrysler rear axle applications in a wide range of ratios, from highway-friendly 2.73s to aggressive 4.56s and beyond.",
    specs: [
      "Available ratios: 2.73, 3.08, 3.42, 3.73, 4.10, 4.56, 4.88+",
      "GM 10-bolt and 12-bolt applications",
      "Ford 8\", 8.8\", 9\" applications",
      "Chrysler 8.25\", 8.75\", Dana 60",
      "Street, performance, and drag racing sets",
      "Installation and setup service available",
    ],
    compatible: [
      "GM 10-bolt (7.5\", 8.2\", 8.5\" ring gear)",
      "GM 12-bolt (8.875\" ring gear)",
      "Ford 8\" and 8.8\" (Mustang, F-150)",
      "Ford 9\" (classic Mustang, performance builds)",
      "Chrysler 8.75\" and Dana 60 (Dodge trucks)",
    ],
    img: "https://images.pexels.com/photos/221028/pexels-photo-221028.jpeg?auto=compress&cs=tinysrgb&w=900",
    imgAlt: "Grayscale close-up of interlocking ring and pinion gear set",
    related: ["positraction-units", "differential-rebuild-kits", "positraction-units"],
  },
  {
    slug: "differential-rebuild-kits",
    name: "Differential Rebuild Kits",
    fullName: "Differential Master Rebuild Kits",
    category: "Rebuild Kits",
    categoryGroup: "Differential & Driveline Parts",
    desc: "A properly rebuilt differential is as important as the gear set itself. Our master rebuild kits include everything you need: carrier bearings, pinion bearings, pinion seal, crush sleeve or solid spacer, shims, and installation hardware. We carry kits for GM, Ford, and Chrysler differentials across a wide range of applications.",
    specs: [
      "Master kit includes: carrier bearings, pinion bearings, seal, shims",
      "Solid pinion spacer kits available (performance)",
      "OEM-spec and performance bearing grades",
      "Application-specific shim assortments",
      "Complete hardware kits included",
      "Available for 10-bolt, 12-bolt, 8\", 8.8\", 9\", Dana 60",
    ],
    compatible: [
      "GM 10-bolt (7.5\", 8.2\", 8.5\")",
      "GM 12-bolt (8.875\")",
      "Ford 8\", 8.8\" (Mustang, Explorer, F-series)",
      "Ford 9\" (classic performance)",
      "Chrysler 8.25\", 8.75\", Dana 44 / Dana 60",
    ],
    img: "https://images.pexels.com/photos/159298/pexels-photo-159298.jpeg?auto=compress&cs=tinysrgb&w=900",
    imgAlt: "Mechanical gear set and bearings for differential rebuild kit",
    related: ["positraction-units", "ring-pinion-sets", "transmission-coolers"],
  },
  {
    slug: "transmission-coolers",
    name: "Transmission Coolers",
    fullName: "External Transmission Coolers",
    category: "Cooling",
    categoryGroup: "Differential & Driveline Parts",
    desc: "Transmission heat is the number one killer of automatic transmissions. An external cooler keeps fluid temps in check during towing, performance driving, or any high-demand application. We carry a range of external coolers sized for light-duty passenger cars up to heavy towing applications, plus installation fittings and line kits.",
    specs: [
      "Plate-and-fin and tube-and-fin designs",
      "Sizes: 6\" × 10\" up to 11\" × 17\"",
      "-6 AN and 5/16\" barb fittings available",
      "Mounting hardware and brackets included",
      "Transmission line kits available",
      "Compatible with all fluid types (Dexron, Mercon, ATF+4)",
    ],
    compatible: [
      "All automatic transmissions with external line ports",
      "GM 700R4, 4L60E, 4L80E, TH400",
      "Ford AOD, 4R70W, 5R55, 6R80",
      "Chrysler 727, 904, 42RLE, 545RFE",
      "Towing, performance, and daily driver applications",
    ],
    img: "https://images.pexels.com/photos/1819668/pexels-photo-1819668.jpeg?auto=compress&cs=tinysrgb&w=900",
    imgAlt: "Automotive transmission cooler radiator for external cooling",
    related: ["700r4-4l60e-parts", "th350-th400-parts", "torque-converters"],
  },
];

export function getStaticPaths() {
  return allParts.map(part => ({
    params: { slug: part.slug },
    props: { part },
  }));
}

const { part } = Astro.props;

// Related parts data
const relatedParts = part.related
  .map(slug => allParts.find(p => p.slug === slug))
  .filter(Boolean)
  .filter((p, i, arr) => arr.findIndex(x => x!.slug === p!.slug) === i)
  .slice(0, 3) as typeof allParts;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": part.fullName,
  "description": part.desc,
  "brand": { "@type": "Brand", "name": "JP Tadduni Transmissions & Driveline" },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "LocalBusiness", "name": "JP Tadduni Transmissions & Driveline" }
  }
});
---

<Layout
  title={`${part.fullName} | JP Tadduni Transmissions, Stratford CT`}
  description={`${part.fullName} — ${part.desc.slice(0, 140)}… Call JP Tadduni in Stratford, CT for pricing and availability.`}
  schema={schema}
>

  <!-- Breadcrumb + Hero -->
  <section class="bg-jp-bg pt-10 pb-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav class="flex items-center gap-2 text-xs text-jp-muted mb-6 font-body uppercase tracking-widest flex-wrap">
        <a href="/" class="hover:text-jp-red transition-colors">Home</a>
        <span>/</span>
        <a href="/parts" class="hover:text-jp-red transition-colors">Parts</a>
        <span>/</span>
        <span class="text-jp-charcoal font-semibold">{part.name}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Product Image -->
        <div class="rounded-card overflow-hidden shadow-card">
          <img
            src={part.img}
            alt={part.imgAlt}
            class="w-full h-80 lg:h-[480px] object-cover"
            loading="eager"
            decoding="async"
          />
        </div>

        <!-- Product Info -->
        <div class="flex flex-col gap-6">

          <div>
            <span class="inline-block text-xs font-semibold uppercase tracking-wider text-jp-red bg-red-50 px-3 py-1 rounded-full mb-3">
              {part.category}
            </span>
            <p class="font-body text-sm text-jp-muted uppercase tracking-widest mb-1">{part.categoryGroup}</p>
            <h1 class="font-heading font-bold text-3xl sm:text-4xl text-jp-charcoal leading-tight">
              {part.fullName}
            </h1>
          </div>

          <p class="font-body text-jp-muted leading-relaxed">{part.desc}</p>

          <!-- Specs -->
          <div>
            <p class="font-heading font-semibold text-jp-charcoal text-sm uppercase tracking-wider mb-3 border-l-2 border-jp-red pl-3">
              Specs & Details
            </p>
            <ul class="flex flex-col gap-2">
              {part.specs.map(spec => (
                <li class="flex items-start gap-3 font-body text-sm text-jp-text">
                  <svg class="w-4 h-4 text-jp-red flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {spec}
                </li>
              ))}
            </ul>
          </div>

          <!-- Compatible Vehicles -->
          <div>
            <p class="font-heading font-semibold text-jp-charcoal text-sm uppercase tracking-wider mb-3 border-l-2 border-jp-red pl-3">
              Compatible Vehicles
            </p>
            <ul class="flex flex-col gap-1.5">
              {part.compatible.map(vehicle => (
                <li class="flex items-center gap-2 font-body text-sm text-jp-muted">
                  <span class="w-1.5 h-1.5 rounded-full bg-jp-red flex-shrink-0"></span>
                  {vehicle}
                </li>
              ))}
            </ul>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3 pt-2 border-t border-jp-border">
            <a href={phoneHref} class="btn-primary flex-1 justify-center">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
              Call to Inquire: {phone}
            </a>
            <a href="/contact" class="btn-secondary flex-1 justify-center">
              Send a Message →
            </a>
          </div>

          <p class="font-body text-xs text-jp-muted">
            Pricing and availability vary. Call or message us and we'll get back to you same day.
          </p>

        </div>
      </div>
    </div>
  </section>

  <!-- Related Parts -->
  {relatedParts.length > 0 && (
    <section class="py-14 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="font-heading font-bold text-2xl text-jp-charcoal mb-8 border-l-4 border-jp-red pl-4">
          Related Parts
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {relatedParts.map(rp => (
            <a href={`/parts/${rp.slug}`} class="parts-card flex flex-col gap-3 group">
              <div class="rounded-md overflow-hidden">
                <img
                  src={rp.img}
                  alt={rp.imgAlt}
                  class="w-full h-44 object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <span class="inline-block text-xs font-semibold uppercase tracking-wider text-jp-red bg-red-50 px-2 py-1 rounded self-start">
                {rp.category}
              </span>
              <h3 class="font-heading font-bold text-base text-jp-charcoal group-hover:text-jp-red transition-colors">
                {rp.name}
              </h3>
              <p class="font-body text-jp-muted text-sm leading-relaxed">
                {rp.desc.slice(0, 100)}…
              </p>
              <span class="font-body text-sm text-jp-red font-semibold mt-auto">View Part →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTABanner />
</Layout>
