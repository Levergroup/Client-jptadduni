---
/**
 * Layout.astro – Root layout for JP Tadduni Transmissions & Driveline
 * Light professional design with red accents and charcoal nav/footer.
 */

import SEOHead from '../components/layout/SEOHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MobileCallBar from '../components/layout/MobileCallBar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: string;
}

const { title, description, canonical, ogImage, schema } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <SEOHead
    title={title}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    schema={schema}
  />
  <body class="min-h-screen flex flex-col bg-jp-bg text-jp-text">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <MobileCallBar />
    <!-- GHL Call Tracking -->
    <script src="https://backend.leadconnectorhq.com/appengine/loc/Eg7w8riiQrXu4UuWw942/pool/n7EqvMtbcZFYyi5JqHMA/number_pool.js"></script>
    <script src="https://backend.leadconnectorhq.com/appengine/js/user_session.js"></script>
  </body>
</html>
