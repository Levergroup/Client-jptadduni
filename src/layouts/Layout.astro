---
/**
 * Layout.astro
 *
 * Root layout shell shared by all pages.
 * Composes SEOHead, Header, the page <slot />, and Footer.
 * Accepts the same SEO props as SEOHead plus an optional JSON-LD schema string.
 */

import SEOHead from '../components/layout/SEOHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: string; // JSON-LD structured data as a serialized string
}

const { title, description, canonical, ogImage, schema } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <SEOHead
    title={title}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    schema={schema}
  />
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
